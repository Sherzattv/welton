---
// Премиум-ощущение скролла: тонкая зелёная полоса прогресса сверху
// + плавный скролл (Lenis) + плавные переходы по якорям меню.
// Всё уважает prefers-reduced-motion.
---

<div aria-hidden="true" class="pointer-events-none fixed inset-x-0 top-0 z-[70] h-[3px]">
  <div data-scroll-progress class="h-full origin-left scale-x-0 bg-accent"></div>
</div>

<script>
  import Lenis from "lenis";

  const bar = document.querySelector<HTMLElement>("[data-scroll-progress]");
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  const updateBar = () => {
    const max = document.documentElement.scrollHeight - window.innerHeight;
    const p = max > 0 ? Math.min(window.scrollY / max, 1) : 0;
    if (bar) bar.style.transform = `scaleX(${p})`;
  };

  if (reduce) {
    window.addEventListener("scroll", updateBar, { passive: true });
  } else {
    const lenis = new Lenis({ duration: 1.1, smoothWheel: true });

    const raf = (time: number) => {
      lenis.raf(time);
      requestAnimationFrame(raf);
    };
    requestAnimationFrame(raf);
    lenis.on("scroll", updateBar);

    // Плавные переходы по якорным ссылкам (#services, #contacts, ...)
    document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((a) => {
      a.addEventListener("click", (e) => {
        const id = a.getAttribute("href");
        if (!id || id === "#") return;
        const target = document.querySelector(id);
        if (!target) return;
        e.preventDefault();
        lenis.scrollTo(target as HTMLElement, { offset: -80 });
      });
    });
  }

  updateBar();
</script>
