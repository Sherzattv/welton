---
// Фирменная кнопка: подпись + вертикальный разделитель + стрелка.
// Острые углы, ховер уводит в красный акцент, стрелка едет вправо.
import Icon from "@ui/Icon.astro";

interface Props {
  href?: string;
  variant?: "light" | "accent" | "outline";
  size?: "auto" | "cta" | "full";
  class?: string;
  type?: "button" | "submit";
  [key: `data-${string}`]: string | boolean | undefined;
}
const {
  href,
  variant = "light",
  size = "auto",
  class: className = "",
  type = "button",
  ...rest
} = Astro.props;
const Tag = href ? "a" : "button";

const base =
  "btn group inline-flex items-stretch justify-between overflow-hidden rounded-[3px] font-medium tracking-[-0.6px] transition-colors duration-200 ease-in-out";
const variants = {
  light: "bg-paper text-charcoal hover:bg-accent hover:text-paper",
  accent: "bg-accent text-paper hover:bg-accent-hover",
  outline:
    "border border-paper/30 text-paper hover:border-accent hover:bg-accent hover:text-paper",
};
const sizes = {
  auto: "",
  cta: "btn--cta",
  full: "btn--full",
};
---

<Tag
  href={href}
  type={href ? undefined : type}
  class={`${base} ${variants[variant]} ${sizes[size]} ${className}`}
  {...rest}
>
  <span class="btn-label flex items-center"><slot /></span>
  <span
    class="btn-icon relative flex items-center justify-center transition-colors duration-300"
  >
    <Icon
      name="arrow-right"
      class="opacity-50 transition-transform duration-200 ease-in-out group-hover:translate-x-1"
    />
  </span>
</Tag>

<style>
  .btn {
    min-height: clamp(48px, 4vw, 58px);
    font-size: clamp(14px, 1.1667vw, 16.8px);
  }

  .btn--cta {
    width: clamp(199px, 16.583vw, 239px);
  }

  .btn--full {
    width: 100%;
  }

  .btn-label {
    padding-left: clamp(16px, 1.333vw, 19.2px);
    padding-right: clamp(12px, 1vw, 14.4px);
    line-height: clamp(21.7px, 1.8083vw, 26.04px);
  }

  .btn-icon {
    width: clamp(44px, 3.6667vw, 52.8px);
  }

  .btn-icon::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    width: 1px;
    height: clamp(29px, 2.4167vw, 34.8px);
    transform: translateY(-50%);
    background: currentColor;
    opacity: 0.3;
  }

  @media (max-width: 639px) {
    .btn {
      min-height: calc(100vw * 48 / 360);
      font-size: calc(100vw * 14 / 360);
    }

    .btn--cta {
      width: calc(100vw * 199 / 360);
    }

    .btn-label {
      padding-left: calc(100vw * 16 / 360);
      padding-right: calc(100vw * 12 / 360);
      line-height: calc(100vw * 21.7 / 360);
    }

    .btn-icon {
      width: calc(100vw * 44 / 360);
    }

    .btn-icon::before {
      height: calc(100vw * 29 / 360);
    }
  }
</style>
