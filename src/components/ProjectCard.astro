---
// Карточка проекта для каталога: обложка, номер, заголовок, мета.
import Heading from "./Heading.astro";

interface Props {
  number?: string;
  title: string;
  location?: string;
  image?: string;
  href?: string;
  class?: string;
}
const {
  number,
  title,
  location,
  image,
  href = "#",
  class: className = "",
} = Astro.props;
---

<a
  href={href}
  class={`group block overflow-hidden rounded-[3px] bg-paper text-charcoal ${className}`}
>
  <div class="relative aspect-[4/5] overflow-hidden rounded-[3px] bg-ink">
    {
      image ? (
        <img
          src={image}
          alt={title}
          loading="lazy"
          decoding="async"
          class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
        />
      ) : (
        <div class="absolute inset-0 bg-gradient-to-br from-grey-500/20 to-ink" />
      )
    }
    {
      number && (
        <span class="display absolute top-4 right-5 text-3xl text-paper/90 mix-blend-difference">
          {number}
        </span>
      )
    }
  </div>
  <div class="flex items-start justify-between gap-4 px-5 py-5">
    <div>
      <Heading as="h3" size="sm" class="text-charcoal">{title}</Heading>
      {
        location && (
          <p class="mt-1 text-sm text-grey-500">{location}</p>
        )
      }
    </div>
    <svg
      width="18"
      height="14"
      viewBox="0 0 18 14"
      fill="none"
      aria-hidden="true"
      class="mt-1 shrink-0 text-charcoal transition-transform duration-300 ease-out group-hover:translate-x-1"
    >
      <path
        d="M11 1l6 6-6 6M17 7H1"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="square"></path>
    </svg>
  </div>
</a>
