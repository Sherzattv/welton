---
// Карточка проекта для каталога.
//   • фото 4:3 со скруглением var(--radius-sm)
//   • поверх фото top-left: мета с иконками (площадь / габариты / этажи)
//     на лёгком верхнем градиенте для читаемости (без подложек)
//   • под фото: название (Adderley) — при hover красится в accent
//     + опциональный tagline в две строки
import Icon from "@ui/Icon.astro";

interface Props {
  title: string;
  code?: string;
  tagline?: string;
  image?: string;
  href?: string;
  area?: number;
  width?: number;
  depth?: number;
  floors?: number;
  class?: string;
}
const {
  title,
  code,
  tagline,
  image,
  href = "#",
  area,
  width,
  depth,
  floors,
  class: className = "",
} = Astro.props;

// Если title совпадает с code — это плейсхолдер (реального названия нет),
// тогда не дублируем код справа.
const showCode = Boolean(code && code !== title);

const fmt = (n: number): string =>
  Number.isInteger(n) ? String(n) : n.toString().replace(".", ",");

const hasMeta =
  area !== undefined ||
  (width !== undefined && depth !== undefined) ||
  floors !== undefined;
---

<a href={href} class={`group block text-charcoal ${className}`}>
  <div class="relative aspect-[4/3] overflow-hidden rounded-[3px] bg-ink">
    {
      image ? (
        <img
          src={image}
          alt={title}
          loading="lazy"
          decoding="async"
          class="absolute inset-0 h-full w-full object-cover transition-transform duration-[1200ms] ease-out group-hover:scale-[1.04]"
        />
      ) : (
        <div class="absolute inset-0 bg-gradient-to-br from-grey-500/20 to-ink" />
      )
    }

    {
      hasMeta && (
        <>
          <div class="pointer-events-none absolute inset-x-0 top-0 h-24 bg-gradient-to-b from-charcoal/60 to-transparent" />
          <ul
            class="absolute top-3 left-4 flex flex-wrap items-center gap-x-4 gap-y-1.5 text-paper"
            role="list"
            aria-label="Характеристики проекта"
          >
            {area !== undefined && (
              <li class="meta-item">
                <Icon
                  name="area"
                  class="text-paper/85"
                  width={14}
                  height={14}
                />
                <span class="meta-value">{fmt(area)} м²</span>
              </li>
            )}
            {width !== undefined && depth !== undefined && (
              <li class="meta-item">
                <Icon
                  name="dimensions"
                  class="text-paper/85"
                  width={18}
                  height={9}
                />
                <span class="meta-value">
                  {fmt(width)} × {fmt(depth)} м
                </span>
              </li>
            )}
            {floors !== undefined && (
              <li class="meta-item">
                <Icon
                  name="floors"
                  class="text-paper/85"
                  width={14}
                  height={14}
                />
                <span class="meta-value">
                  {floors} {floors === 1 ? "этаж" : "этажа"}
                </span>
              </li>
            )}
          </ul>
        </>
      )
    }
  </div>

  <div class="pt-6">
    <div class="flex items-start justify-between gap-3">
      <h3
        class="display min-w-0 text-2xl leading-[1.05] transition-colors duration-300 group-hover:text-accent xl:text-[28px]"
      >
        {title}
      </h3>
      {
        showCode && (
          <span class="mt-1 shrink-0 text-[11px] tracking-[0.16em] text-grey-500 uppercase">
            {code}
          </span>
        )
      }
    </div>
    {
      tagline && (
        <p class="mt-3 max-w-[34ch] text-sm leading-snug text-grey-500">
          {tagline}
        </p>
      )
    }
  </div>
</a>

<style>
  .meta-item {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .meta-value {
    font-size: 12px;
    line-height: 1;
    letter-spacing: -0.2px;
    font-weight: 500;
  }
</style>
