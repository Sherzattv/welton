---
// Карточка проекта для каталога: обложка, номер, заголовок, мета.
// Опциональные area/width/depth/floors включают плитку числовой меты —
// формат: «142 м² · 15×9,5 · 1 этаж». Если ничего не передано — плитка не рендерится.
import Heading from "@components/Heading.astro";
import Icon from "@ui/Icon.astro";

interface Props {
  number?: string;
  title: string;
  location?: string;
  image?: string;
  href?: string;
  area?: number;
  width?: number;
  depth?: number;
  floors?: number;
  class?: string;
}
const {
  number,
  title,
  location,
  image,
  href = "#",
  area,
  width,
  depth,
  floors,
  class: className = "",
} = Astro.props;

const fmt = (n: number): string =>
  Number.isInteger(n) ? String(n) : n.toString().replace(".", ",");

const meta: string[] = [];
if (area !== undefined) meta.push(`${fmt(area)} м²`);
if (width !== undefined && depth !== undefined)
  meta.push(`${fmt(width)}×${fmt(depth)} м`);
if (floors !== undefined)
  meta.push(`${floors} ${floors === 1 ? "этаж" : "этажа"}`);
---

<a
  href={href}
  class={`group block overflow-hidden rounded-[3px] bg-paper text-charcoal ${className}`}
>
  <div class="relative aspect-[4/5] overflow-hidden rounded-[3px] bg-ink">
    {
      image ? (
        <img
          src={image}
          alt={title}
          loading="lazy"
          decoding="async"
          class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
        />
      ) : (
        <div class="absolute inset-0 bg-gradient-to-br from-grey-500/20 to-ink" />
      )
    }
    {
      number && (
        <span class="absolute top-4 right-5 display text-3xl text-paper/90 mix-blend-difference">
          {number}
        </span>
      )
    }
  </div>
  <div class="flex items-start justify-between gap-4 px-5 py-5">
    <div class="min-w-0">
      <Heading as="h3" size="sm" class="text-charcoal">{title}</Heading>
      {location && <p class="mt-1 text-sm text-grey-500">{location}</p>}
      {
        meta.length > 0 && (
          <p class="mt-2 text-sm text-grey-500">{meta.join(" · ")}</p>
        )
      }
    </div>
    <Icon
      name="arrow-right"
      class="mt-1 shrink-0 text-charcoal transition-transform duration-300 ease-out group-hover:translate-x-1"
    />
  </div>
</a>
