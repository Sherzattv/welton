---
// Секция flow-контента: вертикальный ритм из токенов + тон фона + контейнер.
// Канон для будущих страниц (проекты/блог). Артборд-секции главной (Services,
// Stages, Objects, Stats, …) свой ритм задают сами и оборачиваются в <Container>
// напрямую, а не через <Section>.
import Container from "@components/Container.astro";

interface Props {
  tone?: "charcoal" | "paper" | "ink" | "transparent";
  density?: "default" | "sm" | "lg";
  width?: "default" | "prose";
  contained?: boolean;
  class?: string;
  id?: string;
}
const {
  tone = "charcoal",
  density = "default",
  width = "default",
  contained = true,
  class: className = "",
  id,
} = Astro.props;

const toneClass = {
  charcoal: "bg-charcoal text-paper",
  paper: "bg-paper text-charcoal",
  ink: "bg-ink text-paper",
  transparent: "",
}[tone];

const pyVar = {
  default: "var(--section-py)",
  sm: "var(--section-py-sm)",
  lg: "var(--section-py-lg)",
}[density];
---

<section
  id={id}
  class={`section ${toneClass} ${className}`}
  style={`--py:${pyVar}`}
>
  {
    contained ? (
      <Container width={width}>
        <slot />
      </Container>
    ) : (
      <slot />
    )
  }
</section>

<style>
  .section {
    padding-block: var(--py);
  }
</style>
