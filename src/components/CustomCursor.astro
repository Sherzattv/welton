---
// ============================================================
// Кастомный курсор Велес Групп
// ------------------------------------------------------------
// Сдержанный «awwwards-стиль» курсора в духе проекта:
//   • точка 6px + тонкое кольцо 36px с лагом (gsap.quickTo)
//   • mix-blend-mode: difference — сам подстраивается под фон
//   • magnetic-pull на [data-cursor-magnetic] (CTA, иконки)
//   • hover-стейт: на a/button/[data-cursor] кольцо раздувается,
//     точка прячется. Через data-cursor="label" внутри ставим текст
//   • полностью off на touch / pointer:coarse / reduced-motion
//
// Использование:
//   <CustomCursor /> один раз в Layout.astro (перед </body>)
//   на «магнитные» элементы вешаем data-cursor-magnetic
//   на блоки с label-текстом: data-cursor="Открыть" / data-cursor="Перейти"
// ============================================================
---

<div
  data-cursor-root
  class="cursor-root pointer-events-none fixed inset-0 z-[100] hidden motion-safe:block"
  aria-hidden="true"
>
  <div data-cursor-ring class="absolute top-0 left-0 will-change-transform">
    <div
      data-cursor-ring-inner
      class="grid h-9 w-9 -translate-x-1/2 -translate-y-1/2 place-items-center rounded-full border border-paper/90 will-change-transform"
    >
      <span
        data-cursor-label
        class="text-[10px] font-medium tracking-[0.08em] whitespace-nowrap text-paper uppercase opacity-0 select-none"
      ></span>
    </div>
  </div>
  <div data-cursor-dot class="absolute top-0 left-0 will-change-transform">
    <div
      data-cursor-dot-inner
      class="h-1.5 w-1.5 -translate-x-1/2 -translate-y-1/2 rounded-full bg-paper will-change-transform"
    >
    </div>
  </div>
</div>

<style>
  /* На тач-устройствах кастомный курсор полностью скрываем. */
  @media (hover: none), (pointer: coarse) {
    .cursor-root {
      display: none !important;
    }
  }

  /* По умолчанию работаем в blend-режиме: курсор инвертируется под фон.
     На сплошных одноцветных секциях это даёт идеальный контраст.        */
  .cursor-root {
    mix-blend-mode: difference;
  }

  /* Над фото/видео и любым [data-cursor-solid] переключаемся в solid:
     blend-mode отключаем (он плывёт на средних яркостях), а кольцо/точка
     получают двойной drop-shadow — светлый ореол на тёмном, тёмный на
     светлом. Так курсор виден на любой фотке.                            */
  .cursor-root.is-solid {
    mix-blend-mode: normal;
  }
  .cursor-root.is-solid [data-cursor-ring-inner],
  .cursor-root.is-solid [data-cursor-dot-inner] {
    filter: drop-shadow(0 0 1px rgba(0, 0, 0, 0.55))
      drop-shadow(0 1px 6px rgba(0, 0, 0, 0.35));
  }

  /* Скрываем системный курсор только когда наш реально работает
     (десктоп + не reduced-motion). */
  @media (hover: hover) and (pointer: fine) {
    html.motion,
    html.motion a,
    html.motion button,
    html.motion [data-cursor],
    html.motion [data-cursor-magnetic] {
      cursor: none;
    }
  }
</style>

<script>
  import { gsap } from "gsap";

  const REDUCE = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const FINE = window.matchMedia("(hover: hover) and (pointer: fine)").matches;

  if (!REDUCE && FINE) {
    const root = document.querySelector<HTMLElement>("[data-cursor-root]");
    const ring = document.querySelector<HTMLElement>("[data-cursor-ring]");
    const ringInner = document.querySelector<HTMLElement>(
      "[data-cursor-ring-inner]",
    );
    const dot = document.querySelector<HTMLElement>("[data-cursor-dot]");
    const dotInner = document.querySelector<HTMLElement>(
      "[data-cursor-dot-inner]",
    );
    const label = document.querySelector<HTMLElement>("[data-cursor-label]");

    if (root && ring && ringInner && dot && dotInner && label) {
      // Принудительно показываем — Tailwind-класс hidden убираем JS-ом,
      // чтобы при отключённом JS курсор не торчал статикой.
      root.classList.remove("hidden");

      // Точка летит почти мгновенно, кольцо — с лагом (классика).
      // quickTo — официально рекомендуемый GSAP способ анимировать
      // на pointermove (vs gsap.to каждый кадр): кэширует таргет/проп
      // и работает на порядок быстрее. См. /resources/react-basics.
      const dotX = gsap.quickTo(dot, "x", { duration: 0.18, ease: "power3" });
      const dotY = gsap.quickTo(dot, "y", { duration: 0.18, ease: "power3" });
      const ringX = gsap.quickTo(ring, "x", { duration: 0.45, ease: "power3" });
      const ringY = gsap.quickTo(ring, "y", { duration: 0.45, ease: "power3" });

      let mouseX = window.innerWidth / 2;
      let mouseY = window.innerHeight / 2;

      // Когда курсор «приклеен» к магниту — оконный pointermove не должен
      // перетирать ring-позицию, поставленную magnet-логикой. Иначе
      // прилипание к центру магнита не работает (race с всплытием).
      let stuckToMagnet: HTMLElement | null = null;

      window.addEventListener(
        "pointermove",
        (e) => {
          mouseX = e.clientX;
          mouseY = e.clientY;
          dotX(mouseX);
          dotY(mouseY);
          if (!stuckToMagnet) {
            ringX(mouseX);
            ringY(mouseY);
          }
        },
        { passive: true },
      );

      // ----- Hover-стейты -----------------------------------------
      // Внешний слой (ring/dot) получает translate от quickTo,
      // внутренний (ringInner/dotInner) — независимый scale, так что
      // позиция и масштаб не дерутся за одно и то же свойство transform.
      const HOVER_SEL =
        'a, button, [role="button"], [data-cursor], summary, label[for], input[type="submit"]';

      // overwrite: "auto" — отменяет ранее запущенные конфликтующие
      // твины на том же таргете/свойстве. Без него быстрые in/out
      // оставляют анимацию в полузастывшем состоянии.
      const setHover = (el: Element | null) => {
        const cursorAttr = el?.getAttribute?.("data-cursor");
        const text = cursorAttr && cursorAttr !== "true" ? cursorAttr : "";

        gsap.to(ringInner, {
          scale: text ? 2.6 : 1.9,
          duration: 0.35,
          ease: "expo.out",
          transformOrigin: "50% 50%",
          overwrite: "auto",
        });
        gsap.to(dotInner, {
          scale: 0,
          duration: 0.25,
          ease: "expo.out",
          overwrite: "auto",
        });
        if (text) {
          label.textContent = text;
          gsap.to(label, {
            autoAlpha: 1,
            duration: 0.25,
            ease: "expo.out",
            overwrite: "auto",
          });
        }
      };

      const clearHover = () => {
        gsap.to(ringInner, {
          scale: 1,
          duration: 0.4,
          ease: "expo.out",
          overwrite: "auto",
        });
        gsap.to(dotInner, {
          scale: 1,
          duration: 0.3,
          ease: "expo.out",
          overwrite: "auto",
        });
        gsap.to(label, {
          autoAlpha: 0,
          duration: 0.18,
          overwrite: "auto",
          onComplete: () => (label.textContent = ""),
        });
      };

      // Делегирование — работает и для динамически добавленных элементов.
      document.addEventListener("pointerover", (e) => {
        const t = (e.target as Element | null)?.closest?.(HOVER_SEL);
        if (t) setHover(t);
      });
      document.addEventListener("pointerout", (e) => {
        const from = (e.target as Element | null)?.closest?.(HOVER_SEL);
        const to = (e.relatedTarget as Element | null)?.closest?.(HOVER_SEL);
        if (from && from !== to) clearHover();
      });

      // ----- Solid-режим над картинками/видео ---------------------
      // mix-blend-mode: difference красиво работает на однотонных секциях,
      // но на фото/видео плывёт по средним яркостям и курсор теряется.
      // Над такими элементами переключаемся на сплошной цвет + drop-shadow.
      const SOLID_SEL = "img, picture, video, canvas, svg, [data-cursor-solid]";
      const enterSolid = () => root.classList.add("is-solid");
      const leaveSolid = () => root.classList.remove("is-solid");

      document.addEventListener("pointerover", (e) => {
        const t = (e.target as Element | null)?.closest?.(SOLID_SEL);
        if (t) enterSolid();
      });
      document.addEventListener("pointerout", (e) => {
        const from = (e.target as Element | null)?.closest?.(SOLID_SEL);
        const to = (e.relatedTarget as Element | null)?.closest?.(SOLID_SEL);
        if (from && from !== to) leaveSolid();
      });

      // ----- Magnetic-pull ----------------------------------------
      // Элементы с [data-cursor-magnetic] притягивают сам элемент к курсору,
      // а курсор «прилипает» к их центру. Радиус притяжения по умолчанию —
      // bbox элемента; через data-cursor-magnetic-radius="120" можно сделать
      // расширенное поле (как в Mouse-Follower у Cuberto): элемент будет
      // тянуться к курсору уже при подлёте, до пересечения границ.
      const STRENGTH = 0.35;
      const magnets = Array.from(
        document.querySelectorAll<HTMLElement>("[data-cursor-magnetic]"),
      );

      magnets.forEach((el) => {
        const setX = gsap.quickTo(el, "x", { duration: 0.6, ease: "expo.out" });
        const setY = gsap.quickTo(el, "y", { duration: 0.6, ease: "expo.out" });
        const extraRadius =
          parseFloat(el.dataset.cursorMagneticRadius ?? "0") || 0;

        const onMove = (e: PointerEvent) => {
          const r = el.getBoundingClientRect();
          const cx = r.left + r.width / 2;
          const cy = r.top + r.height / 2;
          const dx = e.clientX - cx;
          const dy = e.clientY - cy;

          // Если расширенный радиус задан — гейтим по расстоянию,
          // иначе магнит работает только в пределах bbox (native hover).
          if (extraRadius > 0) {
            const max = Math.max(r.width, r.height) / 2 + extraRadius;
            if (Math.hypot(dx, dy) > max) {
              if (stuckToMagnet === el) {
                stuckToMagnet = null;
                setX(0);
                setY(0);
              }
              return;
            }
          }

          stuckToMagnet = el;
          setX(dx * STRENGTH);
          setY(dy * STRENGTH);
          ringX(cx);
          ringY(cy);
        };

        // Для расширенного радиуса слушаем window (нужно реагировать
        // ещё до того, как курсор зайдёт в bbox).
        const target: Window | HTMLElement = extraRadius > 0 ? window : el;
        target.addEventListener("pointermove", onMove as EventListener, {
          passive: true,
        });

        el.addEventListener("pointerleave", () => {
          if (stuckToMagnet === el) stuckToMagnet = null;
          setX(0);
          setY(0);
        });
      });

      // ----- Скрытие при mouseleave документа ---------------------
      document.addEventListener("mouseleave", () => {
        gsap.to(root, { autoAlpha: 0, duration: 0.2 });
      });
      document.addEventListener("mouseenter", () => {
        gsap.to(root, { autoAlpha: 1, duration: 0.2 });
      });
    }
  }
</script>
