---
// Декоративная вертикальная сетка-направляющая (как в оригинале Tilda).
// Позиции берутся из глобальных CSS-переменных --guide-* — тот же источник,
// что и у sticky-шапки, поэтому линии всегда совпадают по X.
---

<div aria-hidden="true" class="pointer-events-none absolute inset-0 z-0 overflow-hidden">
  <span class="guide-line guide-line-a"></span>
  <span class="guide-line guide-line-b"></span>
  <span class="guide-line guide-line-c"></span>
</div>

<style>
  .guide-line {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 1px;
    background: currentColor;
    opacity: 0.06;
  }
  .guide-line-a {
    left: var(--guide-a);
  }
  .guide-line-b {
    left: var(--guide-b);
  }
  .guide-line-c {
    left: var(--guide-c);
  }
</style>
