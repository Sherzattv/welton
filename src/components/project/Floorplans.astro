---
// Планировки этажей. 1 файл (plan.png) или 2 файла (plan-1.png + plan-2.png).
// Подпись "1-й этаж" / "2-й этаж" по индексу.
import Container from "@components/Container.astro";
import GridLines from "@components/GridLines.astro";
import Heading from "@components/Heading.astro";
import { projectFile } from "@lib/projectAsset";

interface Props {
  folder: string;
  floorplans: string[];
}
const { folder, floorplans } = Astro.props;

const floorLabel = (i: number, total: number): string =>
  total === 1 ? "Планировка" : `${i + 1}-й этаж`;
---

<section class="floorplans relative overflow-hidden bg-paper text-charcoal">
  <GridLines />
  <Container class="relative z-10">
    <Heading as="h2" size="lg" class="floorplans-title" data-split>
      Планировка
    </Heading>
    <div class={`floorplans-grid floorplans-grid--${floorplans.length}`}>
      {
        floorplans.map((file, i) => (
          <figure class="floorplans-figure">
            <img
              src={projectFile(folder, file)}
              alt={floorLabel(i, floorplans.length)}
              loading="lazy"
              decoding="async"
              class="floorplans-image"
            />
            <figcaption class="floorplans-caption text-grey-500">
              {floorLabel(i, floorplans.length)}
            </figcaption>
          </figure>
        ))
      }
    </div>
  </Container>
</section>

<style>
  .floorplans {
    padding-block: clamp(56px, 6vw, 96px);
  }

  .floorplans-title {
    text-transform: uppercase;
  }

  .floorplans-grid {
    margin-top: clamp(28px, 3vw, 48px);
    display: grid;
    gap: clamp(16px, 1.5vw, 28px);
    grid-template-columns: 1fr;
  }

  .floorplans-figure {
    margin: 0;
    background: var(--color-white);
    border: 1px solid var(--color-grey-200);
    border-radius: var(--radius-sm);
    overflow: hidden;
    padding: clamp(16px, 1.5vw, 24px);
  }

  .floorplans-image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
  }

  .floorplans-caption {
    margin-top: clamp(12px, 1vw, 16px);
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  @media (min-width: 960px) {
    .floorplans-grid--2 {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
