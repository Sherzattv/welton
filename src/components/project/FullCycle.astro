---
// Сквозной блок «Полный цикл работ» — одинаковый на всех проектах.
// На десктопе повторяет паттерн проекта/главной: слева sticky-текст,
// справа — последовательность этапов без горизонтальных разделителей.
import Container from "@components/Container.astro";
import GridLines from "@components/GridLines.astro";
import Heading from "@components/Heading.astro";
import { fullCycle } from "@data/projectPage";
---

<section
  id="full-cycle"
  class="cycle relative overflow-hidden bg-paper text-charcoal"
>
  <GridLines />
  <Container class="cycle-inner relative z-10">
    <div class="cycle-rail">
      <div class="cycle-rail-sticky">
        <p class="cycle-eyebrow text-grey-500" data-reveal>Что мы делаем</p>
        <Heading as="h2" size="lg" class="cycle-title" data-split>
          Полный цикл работ
        </Heading>
        <p class="cycle-lead text-grey-500" data-reveal>
          Берём проект под ключ — от первой консультации до сдачи дома. Без
          переключений на подрядчиков и потери качества на стыках.
        </p>
      </div>
    </div>

    <ol class="cycle-list">
      {
        fullCycle.map((step) => (
          <li class="cycle-item" data-reveal>
            <span class="cycle-num display text-grey-400">{step.num}</span>
            <div class="cycle-copy">
              <Heading as="h3" size="md" class="cycle-step-title">
                {step.title}
              </Heading>
              <p class="cycle-desc text-grey-500">{step.desc}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </Container>
</section>

<style>
  .cycle-inner {
    display: grid;
    gap: calc(var(--s) * 42);
    padding-top: calc(var(--s) * 72);
    padding-bottom: calc(var(--s) * 88);
  }

  .cycle-eyebrow {
    font-size: calc(var(--s) * 11);
    line-height: 1;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .cycle-title {
    margin-top: calc(var(--s) * 14);
    max-width: calc(var(--s) * 320);
    text-transform: uppercase;
  }

  .cycle-lead {
    margin-top: calc(var(--s) * 20);
    max-width: calc(var(--s) * 315);
    line-height: 1.45;
  }

  .cycle-list {
    display: grid;
    gap: calc(var(--s) * 30);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .cycle-item {
    display: grid;
    grid-template-columns: calc(var(--s) * 54) minmax(0, 1fr);
    gap: calc(var(--s) * 18);
  }

  .cycle-num {
    font-size: calc(var(--s) * 34);
    line-height: 0.9;
    letter-spacing: -0.03em;
  }

  .cycle-step-title {
    text-transform: uppercase;
  }

  .cycle-desc {
    margin-top: calc(var(--s) * 10);
    max-width: calc(var(--s) * 300);
    line-height: 1.45;
  }

  @media (min-width: 640px) {
    .cycle-inner {
      gap: 56px;
      padding-top: 96px;
      padding-bottom: 112px;
    }

    .cycle-eyebrow {
      font-size: 11px;
    }

    .cycle-title {
      margin-top: 14px;
      max-width: 560px;
    }

    .cycle-lead {
      margin-top: 20px;
      max-width: 560px;
    }

    .cycle-list {
      gap: 36px;
    }

    .cycle-item {
      grid-template-columns: 82px minmax(0, 1fr);
      gap: 28px;
    }

    .cycle-num {
      font-size: 48px;
    }

    .cycle-desc {
      margin-top: 10px;
      max-width: 560px;
    }
  }

  @media (min-width: 960px) {
    .cycle-inner {
      grid-template-columns: minmax(0, 37%) minmax(0, 1fr);
      gap: clamp(48px, 6vw, 112px);
      align-items: start;
      padding-top: clamp(112px, 9vw, 150px);
      padding-bottom: clamp(128px, 10vw, 180px);
    }

    .cycle-rail {
      min-height: 620px;
    }

    .cycle-rail-sticky {
      position: sticky;
      top: clamp(84px, 6vw, 104px);
    }

    .cycle-title,
    .cycle-lead {
      max-width: 31vw;
    }

    .cycle-list {
      gap: clamp(44px, 4vw, 72px);
      padding-top: 0.25vw;
    }

    .cycle-item {
      grid-template-columns: clamp(82px, 7vw, 112px) minmax(0, 1fr);
      gap: clamp(28px, 3vw, 48px);
    }

    .cycle-num {
      font-size: clamp(48px, 5vw, 76px);
    }

    .cycle-desc {
      max-width: 44ch;
    }
  }
</style>
