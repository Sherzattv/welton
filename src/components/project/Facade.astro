---
// Полноразмерный фасад проекта.
import Container from "@components/Container.astro";
import GridLines from "@components/GridLines.astro";
import Heading from "@components/Heading.astro";
import { projectFile } from "@lib/projectAsset";

interface Props {
  folder: string;
  facade: string;
}
const { folder, facade } = Astro.props;
---

<section class="facade relative overflow-hidden bg-charcoal text-paper">
  <GridLines />
  <Container class="relative z-10">
    <Heading as="h2" size="lg" class="facade-title" data-split> Фасад </Heading>
    <figure class="facade-figure">
      <img
        src={projectFile(folder, facade)}
        alt="Фасад"
        loading="lazy"
        decoding="async"
        class="facade-image"
      />
    </figure>
  </Container>
</section>

<style>
  .facade {
    padding-block: clamp(56px, 6vw, 96px);
  }

  .facade-title {
    text-transform: uppercase;
  }

  .facade-figure {
    margin: clamp(28px, 3vw, 48px) 0 0;
    overflow: hidden;
    border-radius: var(--radius-sm);
    background: var(--color-ink);
  }

  .facade-image {
    width: 100%;
    height: auto;
    display: block;
  }
</style>
