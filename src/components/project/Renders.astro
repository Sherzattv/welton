---
// 3D-рендеры проекта. Если список пуст — блок не отрисовывается.
import Container from "@components/Container.astro";
import GridLines from "@components/GridLines.astro";
import Heading from "@components/Heading.astro";
import { projectFile } from "@lib/projectAsset";

interface Props {
  folder: string;
  renders: string[];
}
const { folder, renders } = Astro.props;
---

{
  renders.length > 0 && (
    <section class="renders relative overflow-hidden bg-charcoal text-paper">
      <GridLines />
      <Container class="relative z-10">
        <Heading as="h2" size="lg" class="renders-title" data-split>
          Визуализация
        </Heading>
        <div class={`renders-grid renders-grid--${renders.length}`}>
          {renders.map((file, i) => (
            <figure class="renders-figure">
              <img
                src={projectFile(folder, file)}
                alt={`Рендер ${i + 1}`}
                loading="lazy"
                decoding="async"
                class="renders-image"
              />
            </figure>
          ))}
        </div>
      </Container>
    </section>
  )
}

<style>
  .renders {
    padding-block: clamp(56px, 6vw, 96px);
  }

  .renders-title {
    text-transform: uppercase;
  }

  .renders-grid {
    margin-top: clamp(28px, 3vw, 48px);
    display: grid;
    gap: clamp(16px, 1.5vw, 28px);
    grid-template-columns: 1fr;
  }

  .renders-figure {
    margin: 0;
    overflow: hidden;
    border-radius: var(--radius-sm);
    background: var(--color-ink);
    aspect-ratio: 4 / 3;
  }

  .renders-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 600ms ease-out;
  }

  .renders-figure:hover .renders-image {
    transform: scale(1.03);
  }

  @media (min-width: 640px) {
    .renders-grid--2 {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
