---
// Панель фильтров каталога.
//   • Desktop (≥960px) — sticky сайдбар слева (paper, charcoal-текст).
//   • Mobile (<960px) — bottom-sheet: скрыт по умолчанию, открывается из
//     FAB-кнопки «Фильтры» снизу экрана. Backdrop + handle.
//
// Логика — в @scripts/catalog-filters (debounce, URL state, счётчики).

interface Facet {
  value: string;
  label: string;
}
interface Props {
  total: number;
  categories?: Facet[];
  technologies?: Facet[];
  features?: Facet[];
}
const {
  total,
  categories = [],
  technologies = [],
  features = [],
} = Astro.props;
---

<!-- FAB только на мобиле -->
<button
  type="button"
  class="cf-fab"
  data-cf-fab
  aria-expanded="false"
  aria-controls="catalog-filters-sheet"
>
  <svg
    class="cf-fab-icon"
    width="16"
    height="16"
    viewBox="0 0 16 16"
    fill="none"
    aria-hidden="true"
  >
    <path
      d="M2 4h12M4 8h8M6 12h4"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="square"></path>
  </svg>
  <span class="cf-fab-label">Фильтры</span>
  <span class="cf-fab-count" data-fab-count hidden></span>
</button>

<!-- Backdrop под bottom-sheet (только на мобиле) -->
<div class="cf-backdrop" data-cf-backdrop aria-hidden="true"></div>

<aside
  id="catalog-filters-sheet"
  class="cf"
  aria-label="Фильтры каталога"
  data-catalog-filters
>
  <!-- Шапка bottom-sheet — видна только на мобиле: заголовок + крестик. -->
  <div class="cf-sheet-head">
    <span class="cf-handle" aria-hidden="true"></span>
    <p class="cf-sheet-title">Фильтры</p>
    <button
      type="button"
      class="cf-close"
      data-cf-close
      aria-label="Закрыть фильтры"
    >
      <svg
        width="14"
        height="14"
        viewBox="0 0 14 14"
        fill="none"
        aria-hidden="true"
      >
        <path
          d="M1 1l12 12M13 1L1 13"
          stroke="currentColor"
          stroke-width="1.4"
          stroke-linecap="square"></path>
      </svg>
    </button>
  </div>

  <div class="cf-sticky">
    <!-- Header: «Фильтры» слева, счётчик справа -->
    <header class="cf-header">
      <p class="cf-header-title">Фильтры</p>
      <p class="cf-count" aria-live="polite">
        <span class="cf-count-found" data-filter-count>{total}</span><span
          class="cf-count-total">/<span data-filter-total>{total}</span></span
        >
      </p>
    </header>

    <!-- Утилиты: поиск + сортировка слитной парой, без hairlines между -->
    <div class="cf-utils">
      <div class="cf-search">
        <svg
          class="cf-search-icon"
          width="14"
          height="14"
          viewBox="0 0 14 14"
          fill="none"
          aria-hidden="true"
        >
          <circle cx="6" cy="6" r="4.5" stroke="currentColor" stroke-width="1.3"
          ></circle>
          <path
            d="M9.5 9.5L13 13"
            stroke="currentColor"
            stroke-width="1.3"
            stroke-linecap="square"></path>
        </svg>
        <input
          type="search"
          class="cf-search-input"
          placeholder="Поиск по названию"
          aria-label="Поиск по названию проекта"
          data-search-input
        />
      </div>

      <!-- Sort: квадратная иконка-кнопка с нативным <select> поверх -->
      <div class="cf-sort" title="Сортировка">
        <svg
          class="cf-sort-icon"
          width="16"
          height="16"
          viewBox="0 0 16 16"
          fill="none"
          aria-hidden="true"
        >
          <path
            d="M5 3v10M5 13l-2.5-2.5M5 13l2.5-2.5M11 13V3M11 3l-2.5 2.5M11 3l2.5 2.5"
            stroke="currentColor"
            stroke-width="1.3"
            stroke-linecap="square"></path>
        </svg>
        <label for="cf-sort" class="sr-only">Сортировка</label>
        <select id="cf-sort" data-sort-select aria-label="Сортировка">
          <option value="default">По умолчанию</option>
          <option value="area-asc">Площадь — по возрастанию</option>
          <option value="area-desc">Площадь — по убыванию</option>
          <option value="beds-desc">Больше спален сначала</option>
        </select>
      </div>
    </div>

    <!-- Группы фильтров -->
    <div class="cf-groups">
      {
        categories.length > 0 && (
          <fieldset class="cf-field">
            <legend class="cf-label">Тип объекта</legend>
            <div class="cf-chips" role="group">
              <button
                type="button"
                class="cf-chip is-active"
                data-cat-chip
                data-cat-value="all"
                aria-pressed="true"
              >
                Все{" "}
                <span class="cf-chip-count" data-chip-count>
                  {total}
                </span>
              </button>
              {categories.map((c: Facet) => (
                <button
                  type="button"
                  class="cf-chip"
                  data-cat-chip
                  data-cat-value={c.value}
                  aria-pressed="false"
                >
                  {c.label}{" "}
                  <span class="cf-chip-count" data-chip-count>
                    0
                  </span>
                </button>
              ))}
            </div>
          </fieldset>
        )
      }

      {
        technologies.length > 0 && (
          <fieldset class="cf-field">
            <legend class="cf-label">Технология</legend>
            <div class="cf-chips" role="group">
              <button
                type="button"
                class="cf-chip is-active"
                data-tech-chip
                data-tech-value="all"
                aria-pressed="true"
              >
                Все{" "}
                <span class="cf-chip-count" data-chip-count>
                  {total}
                </span>
              </button>
              {technologies.map((t: Facet) => (
                <button
                  type="button"
                  class="cf-chip"
                  data-tech-chip
                  data-tech-value={t.value}
                  aria-pressed="false"
                >
                  {t.label}{" "}
                  <span class="cf-chip-count" data-chip-count>
                    0
                  </span>
                </button>
              ))}
            </div>
          </fieldset>
        )
      }

      {
        features.length > 0 && (
          <fieldset class="cf-field">
            <legend class="cf-label">Особенности</legend>
            <div class="cf-chips" role="group">
              <button
                type="button"
                class="cf-chip is-active"
                data-feat-chip
                data-feat-value="all"
                aria-pressed="true"
              >
                Все{" "}
                <span class="cf-chip-count" data-chip-count>
                  {total}
                </span>
              </button>
              {features.map((f: Facet) => (
                <button
                  type="button"
                  class="cf-chip"
                  data-feat-chip
                  data-feat-value={f.value}
                  aria-pressed="false"
                >
                  {f.label}{" "}
                  <span class="cf-chip-count" data-chip-count>
                    0
                  </span>
                </button>
              ))}
            </div>
          </fieldset>
        )
      }

      <fieldset class="cf-field">
        <legend class="cf-label">Этажность</legend>
        <div class="cf-chips" role="group">
          <button
            type="button"
            class="cf-chip is-active"
            data-floors-chip
            data-floors-value="all"
            aria-pressed="true"
            >Все <span class="cf-chip-count" data-chip-count>{total}</span
            ></button
          >
          <button
            type="button"
            class="cf-chip"
            data-floors-chip
            data-floors-value="1"
            aria-pressed="false"
            >1 этаж <span class="cf-chip-count" data-chip-count>0</span></button
          >
          <button
            type="button"
            class="cf-chip"
            data-floors-chip
            data-floors-value="2"
            aria-pressed="false"
            >2 этажа <span class="cf-chip-count" data-chip-count>0</span
            ></button
          >
        </div>
      </fieldset>

      <fieldset class="cf-field">
        <legend class="cf-label">Спальни</legend>
        <div class="cf-chips" role="group">
          <button
            type="button"
            class="cf-chip is-active"
            data-beds-chip
            data-beds-value="all"
            aria-pressed="true"
            >Все <span class="cf-chip-count" data-chip-count>{total}</span
            ></button
          >
          <button
            type="button"
            class="cf-chip"
            data-beds-chip
            data-beds-value="1"
            aria-pressed="false"
            >1 <span class="cf-chip-count" data-chip-count>0</span></button
          >
          <button
            type="button"
            class="cf-chip"
            data-beds-chip
            data-beds-value="2"
            aria-pressed="false"
            >2 <span class="cf-chip-count" data-chip-count>0</span></button
          >
          <button
            type="button"
            class="cf-chip"
            data-beds-chip
            data-beds-value="3"
            aria-pressed="false"
            >3 <span class="cf-chip-count" data-chip-count>0</span></button
          >
          <button
            type="button"
            class="cf-chip"
            data-beds-chip
            data-beds-value="4+"
            aria-pressed="false"
            >4+ <span class="cf-chip-count" data-chip-count>0</span></button
          >
        </div>
      </fieldset>

      <fieldset class="cf-field">
        <legend class="cf-label">Площадь, м²</legend>
        <div class="cf-chips" role="group">
          <button
            type="button"
            class="cf-chip is-active"
            data-area-chip
            data-area-value="all"
            aria-pressed="true"
            >Все <span class="cf-chip-count" data-chip-count>{total}</span
            ></button
          >
          <button
            type="button"
            class="cf-chip"
            data-area-chip
            data-area-value="0-80"
            aria-pressed="false"
            >до 80 <span class="cf-chip-count" data-chip-count>0</span></button
          >
          <button
            type="button"
            class="cf-chip"
            data-area-chip
            data-area-value="80-120"
            aria-pressed="false"
            >80–120 <span class="cf-chip-count" data-chip-count>0</span></button
          >
          <button
            type="button"
            class="cf-chip"
            data-area-chip
            data-area-value="120-180"
            aria-pressed="false"
            >120–180 <span class="cf-chip-count" data-chip-count>0</span
            ></button
          >
          <button
            type="button"
            class="cf-chip"
            data-area-chip
            data-area-value="180+"
            aria-pressed="false"
            >180+ <span class="cf-chip-count" data-chip-count>0</span></button
          >
        </div>
      </fieldset>
    </div>

    <!-- Reset — text-link под фильтрами -->
    <button
      type="button"
      class="cf-reset"
      data-filters-reset
      disabled
      aria-label="Сбросить все фильтры">Сбросить все фильтры</button
    >
  </div>

  <!-- Footer bottom-sheet — видна только на мобиле; две равные кнопки -->
  <div class="cf-sheet-foot">
    <button
      type="button"
      class="cf-sheet-btn cf-sheet-btn--outline"
      data-filters-reset
      disabled>Сбросить</button
    >
    <button
      type="button"
      class="cf-sheet-btn cf-sheet-btn--solid"
      data-cf-close
    >
      Показать <span data-sheet-count>{total}</span>
    </button>
  </div>
</aside>

<style>
  .cf {
    background: var(--color-paper);
    color: var(--color-charcoal);
    align-self: stretch;
  }

  .cf-sticky {
    padding: 18px clamp(16px, 1.4vw, 22px);
  }

  /* ─── Шапка/футер sheet — скрыты на десктопе ──────────────── */
  .cf-sheet-head,
  .cf-sheet-foot {
    display: none;
  }

  /* ═══════════ DESKTOP (≥960px) — sticky сайдбар ═══════════ */
  @media (min-width: 960px) {
    .cf-sticky {
      position: sticky;
      top: 0;
      max-height: 100vh;
      overflow-y: auto;
      scrollbar-width: thin;
      scrollbar-color: var(--color-grey-300) transparent;
    }
    .cf-sticky::-webkit-scrollbar {
      width: 6px;
    }
    .cf-sticky::-webkit-scrollbar-thumb {
      background: var(--color-grey-300);
    }

    /* FAB и backdrop — только мобила */
    .cf-fab,
    .cf-backdrop {
      display: none !important;
    }
  }

  /* ═══════════ MOBILE (<960px) — bottom-sheet ═══════════ */
  @media (max-width: 959px) {
    .cf {
      position: fixed;
      inset: auto 0 0 0;
      z-index: 70;
      max-height: 88vh;
      display: flex;
      flex-direction: column;
      transform: translateY(100%);
      transition: transform 320ms cubic-bezier(0.32, 0.72, 0, 1);
      box-shadow: 0 -12px 40px rgba(0, 0, 0, 0.25);
      border-top-left-radius: 12px;
      border-top-right-radius: 12px;
      overflow: hidden;
    }
    .cf.is-open {
      transform: translateY(0);
    }

    .cf-sheet-head {
      padding: 18px 16px 14px;
      position: relative;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }
    .cf-sheet-title {
      margin: 0;
      font-family: var(--font-display);
      font-size: 22px;
      line-height: 1;
      letter-spacing: -0.02em;
      text-transform: uppercase;
      color: var(--color-charcoal);
    }
    .cf-handle {
      position: absolute;
      top: 8px;
      left: 50%;
      transform: translateX(-50%);
      width: 40px;
      height: 4px;
      border-radius: 2px;
      background: var(--color-grey-300);
    }
    .cf-close {
      appearance: none;
      border: 1px solid var(--color-grey-300);
      background: transparent;
      color: var(--color-charcoal);
      width: 36px;
      height: 36px;
      border-radius: var(--radius-sm);
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .cf-close:hover {
      border-color: var(--color-charcoal);
    }

    .cf-sticky {
      position: static;
      max-height: none;
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
      flex: 1 1 auto;
      padding: 18px 18px 20px;
    }

    /* На мобиле header (со счётчиком) и reset в теле — скрываем,
       всё что нужно есть в sheet-head/foot */
    .cf-header,
    .cf-sticky > .cf-reset {
      display: none !important;
    }

    /* Утилиты: поиск + сортировка слитной парой */
    .cf-utils {
      gap: 8px;
      margin-bottom: 22px;
    }

    /* Поиск — облегчённый (без жирной charcoal-рамки) */
    .cf-search-input {
      background: var(--color-grey-200);
      border-color: transparent;
      padding: 12px 14px 12px 40px;
      font-size: 14px;
      font-weight: 400;
    }
    .cf-search-input:focus {
      background: var(--color-grey-200);
      border-color: var(--color-charcoal);
    }
    .cf-search-icon {
      color: var(--color-grey-500);
      left: 14px;
    }

    /* Sort — облегчённая, серая рамка */
    .cf-sort {
      width: 46px;
      border-color: var(--color-grey-300);
    }

    /* Группы — разделены spacing'ом, БЕЗ линий, как iOS Settings */
    .cf-groups {
      gap: 16px;
    }
    .cf-groups .cf-field {
      padding: 0;
      border: 0;
    }

    /* Лейблы — более заметные, тёмные */
    .cf-label {
      font-size: 11px;
      letter-spacing: 0.16em;
      color: var(--color-charcoal);
      padding-bottom: 10px;
      font-weight: 600;
    }

    /* Чипы — пилюли, плотные */
    .cf-chip {
      padding: 10px 14px;
      font-size: 13px;
      gap: 5px;
    }

    /* Footer-кнопки скромнее, не доминируют */
    .cf-sheet-btn {
      padding: 14px 16px;
      font-size: 14px;
    }

    /* Шапка sheet — компактнее, ровный baseline */
    .cf-sheet-head {
      padding: 16px 18px 12px;
    }
    .cf-sheet-title {
      font-size: 20px;
    }
    .cf-close {
      width: 32px;
      height: 32px;
    }

    /* Тело sheet — стандартный 18px паддинг */
    .cf-sticky {
      padding: 16px 18px 22px;
    }

    .cf-sheet-foot {
      display: grid;
      grid-template-columns: 1fr 1.6fr;
      gap: 10px;
      padding: 14px 18px 16px;
      border-top: 1px solid var(--color-grey-200);
      background: var(--color-paper);
      flex-shrink: 0;
    }
    .cf-sheet-btn {
      appearance: none;
      padding: 16px 18px;
      font-size: 15px;
      line-height: 1;
      letter-spacing: -0.2px;
      border-radius: var(--radius-sm);
      cursor: pointer;
      font-weight: 500;
      transition:
        background 160ms ease,
        color 160ms ease,
        border-color 160ms ease;
    }
    .cf-sheet-btn--outline {
      border: 1px solid var(--color-charcoal);
      background: transparent;
      color: var(--color-charcoal);
    }
    .cf-sheet-btn--outline[disabled] {
      border-color: var(--color-grey-300);
      color: var(--color-grey-400);
      cursor: default;
    }
    .cf-sheet-btn--solid {
      border: 1px solid var(--color-charcoal);
      background: var(--color-charcoal);
      color: var(--color-paper);
    }
    .cf-sheet-btn--solid:hover {
      background: var(--color-accent);
      border-color: var(--color-accent);
    }
  }

  /* ─── FAB-кнопка (мобила, fixed bottom) ──────────────────── */
  .cf-fab {
    position: fixed;
    bottom: 16px;
    left: 16px;
    right: 16px;
    z-index: 60;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    appearance: none;
    border: 1px solid var(--color-charcoal);
    background: var(--color-paper);
    color: var(--color-charcoal);
    padding: 16px 20px;
    font-size: 14px;
    line-height: 1;
    letter-spacing: -0.2px;
    border-radius: var(--radius-sm);
    cursor: pointer;
    box-shadow: 0 12px 32px rgba(14, 16, 15, 0.22);
    transition:
      background 160ms ease,
      color 160ms ease,
      transform 200ms ease;
  }
  .cf-fab:active {
    transform: scale(0.98);
  }
  .cf-fab:hover {
    background: var(--color-charcoal);
    color: var(--color-paper);
  }
  .cf-fab.is-hidden {
    display: none;
  }

  /* Скрываем FAB когда открыто меню сайта (Header выставляет html.lenis-stopped) */
  :global(html.lenis-stopped) .cf-fab {
    display: none;
  }
  .cf-fab-icon {
    color: currentColor;
  }
  .cf-fab-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 22px;
    height: 22px;
    padding: 0 6px;
    background: var(--color-accent);
    color: var(--color-paper);
    border-radius: 11px;
    font-family: var(--font-display);
    font-size: 12px;
    line-height: 1;
  }

  /* ─── Backdrop ─────────────────────────────────────────────── */
  .cf-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(14, 16, 15, 0.55);
    z-index: 65;
    opacity: 0;
    pointer-events: none;
    transition: opacity 320ms ease;
  }
  .cf-backdrop.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  /* Когда sheet открыт — body фиксируется, чтобы фон не дёргался при свайпе */
  :global(html.cf-locked) {
    overflow: hidden;
    overscroll-behavior: contain;
  }
  :global(html.cf-locked body) {
    position: fixed;
    left: 0;
    right: 0;
    width: 100%;
    overflow: hidden;
  }

  /* ─── Header (счётчик) ──────────────────────────────────────── */
  /* ─── Header: счётчик + reset в одной строке ─────────────── */
  .cf-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 16px;
  }

  .cf-header-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(20px, 1.6vw, 24px);
    line-height: 1;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--color-charcoal);
  }

  .cf-count {
    font-family: var(--font-display);
    font-size: clamp(20px, 1.6vw, 24px);
    line-height: 1;
    letter-spacing: -0.02em;
    margin: 0;
    display: inline-flex;
    align-items: baseline;
  }

  .cf-count-total {
    color: var(--color-grey-400);
    font-size: 0.5em;
    margin-left: 4px;
  }

  /* ─── Утилиты: поиск + сортировка в одной строке ─────────── */
  .cf-utils {
    display: flex;
    align-items: stretch;
    gap: 8px;
    margin-bottom: 18px;
  }

  .cf-utils .cf-search {
    flex: 1 1 auto;
    min-width: 0;
  }

  /* ─── Группы фильтров — разделены spacing, не hairlines ─── */
  .cf-groups {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* ─── Группа фильтров ───────────────────────────────────────── */
  .cf-field {
    border: 0;
    padding: 0;
    margin: 0;
  }

  .cf-label {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 0 0 8px;
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-charcoal);
    font-weight: 500;
  }

  .cf-label :global(svg) {
    flex-shrink: 0;
    color: var(--color-grey-500);
  }

  /* ─── Поиск ─────────────────────────────────────────────────── */
  .cf-search {
    position: relative;
    display: flex;
    align-items: center;
