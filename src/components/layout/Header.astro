---
import Container from "@components/Container.astro";
import Logo from "@components/Logo.astro";
import Icon from "@ui/Icon.astro";
import SlideLink from "@ui/SlideLink.astro";
import { nav, contact } from "@data/site";
import { asset } from "@lib/asset";

const homePath = asset("/");
const currentPath = Astro.url.pathname.replace(/\/index\.html$/, "/");
const isHomePage =
  currentPath === homePath ||
  currentPath === homePath.replace(/\/$/, "") ||
  `${currentPath}/` === homePath;

const navHref = (href: string) => {
  if (href.startsWith("#")) return isHomePage ? href : asset(`/${href}`);
  if (href.startsWith("/")) return asset(href);
  return href;
};
---

<header
  data-header-top
  class="top-header absolute inset-x-0 top-0 z-50 h-[69px] lg:h-16 xl:h-[76px]"
>
  <div
    aria-hidden="true"
    class="header-guides pointer-events-none absolute inset-0"
  >
    <span class="header-guide header-guide-a"></span>
    <span class="header-guide header-guide-b"></span>
    <span class="header-guide header-guide-c"></span>
    <span class="header-guide-bottom"></span>
  </div>

  <Container class="relative flex h-full items-stretch justify-between">
    <!-- Левая группа: логотип + меню -->
    <div class="flex items-stretch gap-7">
      <a
        href={asset("/")}
        aria-label="welton — на главную"
        class="flex items-center"
      >
        <Logo class="h-[26px] w-auto lg:h-[24px] xl:h-[28px]" />
      </a>

      <nav class="hidden lg:block">
        {
          nav.map((item, index) => {
            const left = ["26.25%", "50.42%", "57.33%", "63.33%", "74.75%"][
              index
            ];
            return (
              <SlideLink
                href={navHref(item.href)}
                text={item.label}
                style={`left:${left}`}
                class="nav-link absolute top-1/2 -translate-y-1/2 text-[12px] leading-[1.55] font-medium tracking-[-0.3px] xl:text-[14px]"
              />
            );
          })
        }
      </nav>
    </div>

    <!-- Правая группа: телефон / бургер -->
    <div class="flex items-stretch gap-7">
      <SlideLink
        href={contact.phoneHref}
        text={contact.phone}
        class="nav-link relative hidden self-center text-[12px] leading-[1.55] font-medium tracking-[-0.3px] lg:block xl:text-[14px]"
      />

      <button
        type="button"
        data-menu-toggle
        aria-label="Открыть меню"
        aria-expanded="false"
        aria-controls="site-menu"
        class="burger relative z-50 cursor-pointer self-center lg:hidden"
      >
        <span></span><span></span><span></span><span></span>
      </button>
    </div>

    <!-- В оригинале шапка лежит поверх первого экрана без собственного фона и рамки. -->
  </Container>
</header>

<!-- Затемнение под меню (мобила/планшет): мягко прокрашивается, пока панель едет. -->
<div
  data-menu-overlay
  class="invisible fixed inset-0 z-30 bg-charcoal/40 opacity-0 transition-opacity duration-300 ease-out lg:hidden"
>
</div>

<!-- Меню на весь экран (мобила/планшет). -->
<aside
  id="site-menu"
  data-menu
  role="dialog"
  aria-modal="true"
  aria-hidden="true"
  aria-labelledby="site-menu-title"
  class="site-menu fixed inset-0 z-[60] flex translate-x-full flex-col bg-charcoal text-paper lg:hidden"
>
  <h2 id="site-menu-title" class="sr-only">Меню навигации</h2>

  <!-- Топ-бар внутри меню повторяет геометрию хедера: логотип и крестик
       встают точно туда, где были логотип и бургер — без визуального прыжка. -->
  <div
    class="menu-topbar relative flex h-[69px] shrink-0 items-stretch xl:h-[76px]"
  >
    <Container class="relative flex h-full items-stretch justify-between">
      <a
        href={asset("/")}
        data-menu-link
        aria-label="welton — на главную"
        class="flex items-center"
      >
        <Logo class="h-[26px] w-auto xl:h-[28px]" />
      </a>

      <button
        type="button"
        data-menu-toggle
        aria-label="Закрыть меню"
        aria-expanded="false"
        aria-controls="site-menu"
        class="burger relative z-50 cursor-pointer self-center"
      >
        <span></span><span></span><span></span><span></span>
      </button>
    </Container>
    <span
      aria-hidden="true"
      class="menu-topbar-hairline pointer-events-none absolute bottom-0 h-px bg-paper/10"
    ></span>
  </div>

  <!-- Пронумерованные пункты: 01–05 + display uppercase + стрелка-аффорданс. -->
  <nav class="menu-nav min-h-0 flex-1 overflow-y-auto">
    <Container as="ul">
      {
        nav.map((item, i) => (
          <li class="menu-item" style={`--i:${i}`}>
            <a
              href={navHref(item.href)}
              data-menu-link
              class="menu-link group flex items-center justify-between gap-4 border-b border-paper/10 py-[clamp(18px,4.5vw,30px)] text-paper transition-colors duration-200 hover:text-accent focus-visible:text-accent focus-visible:outline-none"
            >
              <span class="flex items-baseline gap-[clamp(16px,5vw,32px)]">
                <span class="text-[12px] font-medium tracking-[0.14em] text-grey-500 uppercase">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <span class="display text-[clamp(32px,9vw,56px)] leading-[0.95] tracking-[-0.01em]">
                  {item.label}
                </span>
              </span>
              <Icon
                name="arrow-right"
                width={20}
                height={14}
                class="shrink-0 transition-transform duration-300 ease-out group-hover:translate-x-1 group-focus-visible:translate-x-1"
              />
            </a>
          </li>
        ))
      }
    </Container>
  </nav>

  <!-- Низ: большой телефон + email (как в футере), под чертой соцсети текстом. -->
  <div class="menu-foot shrink-0">
    <Container
      class="pt-[clamp(28px,6vw,44px)] pb-[max(28px,env(safe-area-inset-bottom))]"
    >
      <div
        class="flex flex-col gap-[clamp(6px,1vw,10px)] border-b border-paper/10 pb-[clamp(24px,5vw,32px)]"
      >
        <a
          href={contact.phoneHref}
          data-menu-link
          class="block display text-[clamp(28px,7vw,44px)] leading-none transition-colors duration-200 hover:text-accent focus-visible:text-accent focus-visible:outline-none"
        >
          {contact.phone}
        </a>
        <a
          href={contact.emailHref}
          data-menu-link
          class="block display text-[clamp(18px,4.5vw,28px)] leading-none break-all transition-colors duration-200 hover:text-accent focus-visible:text-accent focus-visible:outline-none"
        >
          {contact.email}
        </a>
      </div>
      <div
        class="mt-[clamp(20px,4vw,28px)] flex items-center gap-5 text-[12px] font-medium tracking-[0.16em] text-grey-400 uppercase"
      >
        <a
          href={contact.instagram}
          target="_blank"
          rel="noopener"
          data-menu-link
          class="transition-colors duration-200 hover:text-accent focus-visible:text-accent focus-visible:outline-none"
        >
          Instagram
        </a>
      </div>
    </Container>
  </div>
</aside>

<style>
  .top-header {
    color: var(--color-paper);
    background: transparent;
  }
  .header-sticky {
    color: var(--color-charcoal);
    background: var(--color-paper);
    transform: translateY(-100%);
    transition: transform 500ms linear;
    pointer-events: none;
  }
  .header-sticky[data-mode="sticky"] {
    transform: translateY(0);
    pointer-events: auto;
  }
  /* В «top»-зоне (верх страницы) sticky обязана быть невидимой без шлейфа:
     если бы здесь дотягивалась анимация 350ms slide-out, пользователь видел бы
     остаток уезжающей белой шапки уже стоя на y=0 — особенно при быстром скролле. */
  .header-sticky[data-mode="top"] {
    transition: none;
  }
  .header-guides {
    color: var(--color-charcoal);
    opacity: 0;
    transition: opacity 160ms linear;
  }
  .header-sticky .header-guides {
    opacity: 1;
  }
  .header-guide {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 1px;
    background: currentColor;
    opacity: var(--guide-opacity, 0.02);
  }
  .header-guide-a {
    left: var(--guide-a);
  }
  .header-guide-b {
    left: var(--guide-b);
  }
  .header-guide-c {
    left: var(--guide-c);
  }
  .header-guide-bottom {
    position: absolute;
    left: var(--guide-edge-left);
    right: var(--guide-edge-right);
    bottom: 0;
    height: 1px;
    background: currentColor;
    opacity: var(--guide-opacity, 0.02);
  }

  /* Бургер: две тонкие линии шириной ~45px, как в оригинале. */
  .burger {
    height: 40px;
    width: 45px;
  }
  /* Расширенная мобильная hit-area без визуального увеличения. */
  .burger::before {
    content: "";
    position: absolute;
    inset: -8px;
  }
  .burger span {
    position: absolute;
    left: 0;
    right: 0;
    height: 1px;
    background: currentColor;
    transition:
      transform 0.3s ease-in-out,
      opacity 0.3s ease-in-out;
  }
  .burger span:nth-child(1) {
    top: 13px;
  }
  .burger span:nth-child(2),
  .burger span:nth-child(3) {
    display: none;
  }
  .burger span:nth-child(4) {
    bottom: 13px;
  }
  .burger[aria-expanded="true"] span:nth-child(1) {
    top: 50%;
    transform: translateY(-50%) rotate(45deg);
  }
  .burger[aria-expanded="true"] span:nth-child(4) {
    bottom: 50%;
    transform: translateY(50%) rotate(-45deg);
  }
  /* Бургер должен оставаться видимым поверх открытого меню. Его цвет инвертируем
     в открытом состоянии — фон шторки тёмный, иконка светлая. */
  .burger[aria-expanded="true"] {
    color: var(--color-paper);
  }

  /* Меню: смягчённая кривая входа, чтобы панель «доводилась», а не вылетала.
     В закрытом состоянии убираем из layout: иначе off-canvas увеличивает
     scrollWidth и ломает визуальные срезы/может дать горизонтальный скролл. */
  .site-menu {
    display: none;
    visibility: hidden;
    transition:
      translate 420ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 420ms cubic-bezier(0.22, 1, 0.36, 1),
      visibility 0s linear 420ms;
  }
  .site-menu[aria-hidden="false"] {
    display: flex;
    visibility: visible;
    transition:
      translate 420ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .menu-topbar-hairline {
    left: var(--guide-edge-left);
    right: var(--guide-edge-right);
  }

  /* Stagger: пункты и низ оживают сразу, как панель пошла. */
  .menu-item,
  .menu-foot {
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 360ms ease-out,
      transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .menu-item {
    transition-delay: calc(140ms + 50ms * var(--i, 0));
  }
  .menu-foot {
    transition-delay: 420ms;
  }
  [data-menu][aria-hidden="false"] .menu-item,
  [data-menu][aria-hidden="false"] .menu-foot {
    opacity: 1;
    transform: none;
  }

  /* Acessibility: уважаем reduced-motion — никаких сдвигов, только мгновенное появление. */
  @media (prefers-reduced-motion: reduce) {
    .site-menu {
      transition: none;
    }
    .menu-item,
    .menu-foot {
      transition: none;
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  const topHeader = document.querySelector<HTMLElement>("[data-header-top]");
  let stickyHeader: HTMLElement | null = null;

  // В Tilda это две разные шапки: верхняя статично лежит в hero,
  // а белая fixed-шапка отдельно появляется только при обратном скролле.
  if (topHeader) {
    stickyHeader = topHeader.cloneNode(true) as HTMLElement;
    stickyHeader.removeAttribute("data-header-top");
    stickyHeader.setAttribute("data-header-sticky", "");
    stickyHeader.dataset.mode = "hidden";
    stickyHeader.className =
      "header-sticky fixed inset-x-0 top-0 z-50 h-[69px] lg:h-16 xl:h-[76px]";
    topHeader.after(stickyHeader);
  }

  const toggles =
    document.querySelectorAll<HTMLButtonElement>("[data-menu-toggle]");
  const menu = document.querySelector<HTMLElement>("[data-menu]");
  const overlay = document.querySelector<HTMLElement>("[data-menu-overlay]");
  const menuLinks =
    document.querySelectorAll<HTMLAnchorElement>("[data-menu-link]");

  // Кнопка, открывшая меню, — чтобы вернуть фокус ей при закрытии.
  let opener: HTMLElement | null = null;

  let lastY = Math.max(window.scrollY, 0);
  let ticking = false;
  // Гистерезис у порога: «заряжаем» появление sticky только после ARM_AT,
  // снимаем заряд ниже HIDE_AT. Зазор 800–900 — мёртвая зона, в которой
  // шапка не успевает мелькнуть при возврате к началу страницы.
  const ARM_AT = 900;
  const HIDE_AT = 800;
  let armed = false;

  const syncHeader = () => {
    if (!stickyHeader) return;
    const y = Math.max(window.scrollY, 0);
    const delta = y - lastY;
    const scrollingUp = delta < -1;
    const scrollingDown = delta > 1;

    if (y >= ARM_AT) armed = true;
    if (y < HIDE_AT) armed = false;

    if (!armed) {
      // Мы в верхней зоне — снап без анимации, чтобы хвост слайд-аута
      // не «дотягивался» до экрана уже после того, как юзер встал на y=0.
      stickyHeader.dataset.mode = "top";
    } else if (scrollingUp) {
      stickyHeader.dataset.mode = "sticky";
    } else if (scrollingDown) {
      stickyHeader.dataset.mode = "hidden";
    }

    lastY = y;
    ticking = false;
  };

  window.addEventListener(
    "scroll",
    () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(syncHeader);
      }
    },
    { passive: true },
  );
  syncHeader();

  let closeTimer: number | undefined;

  const setOpen = (open: boolean) => {
    if (!menu || !overlay) return;
    if (closeTimer) window.clearTimeout(closeTimer);

    toggles.forEach((toggle) =>
      toggle.setAttribute("aria-expanded", String(open)),
    );
    overlay.classList.toggle("invisible", !open);
    overlay.classList.toggle("opacity-0", !open);
    // Скролл-лок: и для Lenis (через класс), и для тех окружений, где Lenis не активен.
    document.documentElement.classList.toggle("lenis-stopped", open);
    document.body.style.overflow = open ? "hidden" : "";

    if (open) {
      menu.setAttribute("aria-hidden", "false");
      menu.classList.add("translate-x-full");
      menu.classList.remove("translate-x-0");
      // Даем браузеру зафиксировать стартовую позицию display:flex + translate-x-full,
      // затем запускаем transition в translate-x-0.
      void menu.offsetWidth;
      requestAnimationFrame(() => {
        menu.classList.remove("translate-x-full");
        menu.classList.add("translate-x-0");
      });

      // Фокус — на первую интерактивную ссылку, чтобы клавиатура / screen-reader сразу попали внутрь.
      const firstLink = menu.querySelector<HTMLElement>("a[href]");
      firstLink?.focus({ preventScroll: true });
    } else {
      menu.classList.add("translate-x-full");
      menu.classList.remove("translate-x-0");
      closeTimer = window.setTimeout(() => {
        menu.setAttribute("aria-hidden", "true");
      }, 420);

      opener?.focus({ preventScroll: true });
      opener = null;
    }
  };

  toggles.forEach((toggle) => {
    toggle.addEventListener("click", () => {
      const wasOpen = toggle.getAttribute("aria-expanded") === "true";
      if (!wasOpen) opener = toggle;
      setOpen(!wasOpen);
    });
  });
  overlay?.addEventListener("click", () => setOpen(false));
  menuLinks.forEach((l) => l.addEventListener("click", () => setOpen(false)));

  document.addEventListener("keydown", (e) => {
    if (menu?.getAttribute("aria-hidden") !== "false") return;
    if (e.key === "Escape") {
      setOpen(false);
      return;
    }
    if (e.key === "Tab") {
      // Фокус-трэп: Tab не уходит за пределы открытого меню.
      const focusables = menu.querySelectorAll<HTMLElement>(
        "a[href], button:not([disabled])",
      );
      if (!focusables.length) return;
      const first = focusables[0];
      const last = focusables[focusables.length - 1];
      const active = document.activeElement as HTMLElement | null;
      if (e.shiftKey && active === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && active === last) {
        e.preventDefault();
        first.focus();
      }
    }
  });
</script>
