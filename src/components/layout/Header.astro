---
import Container from "../Container.astro";
import { nav, contact } from "../../data/home";
---

<header
  data-header-top
  class="top-header absolute inset-x-0 top-0 z-50 h-[69px] lg:h-16 xl:h-[76px]"
>
  <div aria-hidden="true" class="header-guides pointer-events-none absolute inset-0">
    <span class="header-guide header-guide-a"></span>
    <span class="header-guide header-guide-b"></span>
    <span class="header-guide header-guide-c"></span>
    <span class="header-guide-bottom"></span>
  </div>

  <Container class="relative flex h-full items-stretch justify-between">
    <!-- Левая группа: логотип + меню -->
    <div class="flex items-stretch gap-7">
      <a href="/" aria-label="Велес Групп — на главную" class="flex items-center">
        <svg
          width="71"
          height="32"
          viewBox="0 0 80 36"
          fill="currentColor"
          aria-hidden="true"
          class="h-[35px] w-[77px] lg:h-8 lg:w-[71px] xl:h-[38px] xl:w-[85px]"
        >
          <path d="M74.8396 35.9582H72.4445V20.7387H80V35.9582H77.5613V22.9129H74.8396V35.9582Z"></path>
          <path d="M65.7652 35.9582H63.3701V20.7387H70.9256V35.9582H68.487V22.9129H65.7652V35.9582Z"></path>
          <path d="M60.0125 32.0881C59.7077 33.5665 59.2505 34.5812 58.6408 35.132C57.915 35.7987 56.761 36.0814 55.1788 35.9799V33.8492C55.832 33.8927 56.311 33.8347 56.6158 33.6752C56.9787 33.4868 57.2037 33.1317 57.2908 32.6099L57.3126 32.4794L54.003 20.7387H56.3763L57.6827 25.935L58.423 29.5007L58.9892 25.9568L60.0779 20.7387H62.5818L60.0125 32.0881Z"></path>
          <path d="M50.2372 20.7387C52.6178 20.7387 53.8081 21.9925 53.8081 24.5001V26.4786C53.8081 28.9862 52.6178 30.24 50.2372 30.24H49.1049V35.9582H46.7098V20.7387H50.2372ZM49.1049 22.9129V28.0658H50.2372C51.021 28.0658 51.413 27.5874 51.413 26.6308V24.3479C51.413 23.3912 51.021 22.9129 50.2372 22.9129H49.1049Z"></path>
          <path d="M38.9968 35.9582V20.7387H45.3112V22.9129H41.3919V35.9582H38.9968Z"></path>
          <path d="M79.7305 11.8863V13.9083C79.7305 16.4594 78.5402 17.7349 76.1596 17.7349C73.779 17.7349 72.5887 16.4594 72.5887 13.9083V5.99417C72.5887 3.44309 73.779 2.16756 76.1596 2.16756C78.5402 2.16756 79.7305 3.44309 79.7305 5.99417V7.47263H77.4661V5.84197C77.4661 4.84184 77.0524 4.34177 76.225 4.34177C75.3976 4.34177 74.9839 4.84184 74.9839 5.84197V14.0605C74.9839 15.0461 75.3976 15.539 76.225 15.539C77.0524 15.539 77.4661 15.0461 77.4661 14.0605V11.8863H79.7305Z"></path>
          <path d="M67.3813 8.75542H70.6691V10.9296H67.3813V15.3868H71.5183V17.561H64.9862V2.3415H71.5183V4.51571H67.3813V8.75542Z"></path>
          <path d="M54.7264 15.4085C55.3071 15.4085 55.6845 15.3215 55.8587 15.1476C56.0764 14.9592 56.1925 14.5243 56.2071 13.8431L56.599 2.3415H63.3706V17.561H60.932V4.51571H58.8417L58.5804 13.7126C58.5369 15.1041 58.2465 16.097 57.7094 16.6913C57.1724 17.2856 56.3014 17.5827 55.0966 17.5827H54.7264V15.4085Z"></path>
          <path d="M49.998 8.75542H53.2858V10.9296H49.998V15.3868H54.135V17.561H47.6029V2.3415H54.135V4.51571H49.998V8.75542Z"></path>
          <path d="M42.5894 2.3415C44.9555 2.3415 46.1386 3.50833 46.1386 5.84198V6.38553C46.1386 7.95097 45.6232 8.97285 44.5926 9.45117C45.7829 9.915 46.3781 11.0021 46.3781 12.7125V13.9518C46.3781 16.3579 45.166 17.561 42.7419 17.561H38.975V2.3415H42.5894ZM41.3701 10.7122V15.3868H42.7419C43.5693 15.3868 43.983 14.8867 43.983 13.8866V12.5603C43.983 11.8645 43.8596 11.379 43.6128 11.1036C43.3806 10.8427 42.9886 10.7122 42.437 10.7122H41.3701ZM41.3701 4.51571V8.538H42.3064C43.2644 8.538 43.7434 8.0017 43.7434 6.92909V6.08114C43.7434 5.03752 43.337 4.51571 42.5241 4.51571H41.3701Z"></path>
          <path d="M33.0794 22.8635V35.9581H0V22.8635L22.1925 17.4594L33.0794 22.8635ZM22.1925 33.6718H30.7997V24.1106L22.1925 19.7458V33.6718Z"></path>
          <path d="M33.0794 9.35327V21.8243L22.1925 16.4202L0 21.8243V9.35327L22.1925 0L33.0794 9.35327ZM22.1925 14.1338L30.9857 18.7065V9.97682L22.1925 2.28635V14.1338Z"></path>
        </svg>
      </a>

      <nav class="hidden lg:block">
        {
          nav.map((item, index) => {
            const left = ["26.25%", "50.42%", "57.33%", "63.33%", "74.75%"][index];
            return (
              <a
                href={item.href}
                style={`left:${left}`}
                class="nav-link link-slide absolute top-1/2 -translate-y-1/2 text-[12px] font-medium leading-[1.55] tracking-[-0.3px] xl:text-[14px]"
              >
                <span class="slide-text" data-text={item.label}>{item.label}</span>
              </a>
            );
          })
        }
      </nav>
    </div>

    <!-- Правая группа: телефон / бургер -->
    <div class="flex items-stretch gap-7">
      <a
        href={contact.phoneHref}
        class="nav-link link-slide relative hidden self-center text-[12px] font-medium leading-[1.55] tracking-[-0.3px] lg:block xl:text-[14px]"
      >
        <span class="slide-text" data-text={contact.phone}>{contact.phone}</span>
      </a>

      <button
        type="button"
        data-menu-toggle
        aria-label="Меню"
        aria-expanded="false"
        class="burger relative z-50 self-center cursor-pointer lg:hidden"
      >
        <span></span><span></span><span></span><span></span>
      </button>
    </div>

    <!-- В оригинале шапка лежит поверх первого экрана без собственного фона и рамки. -->
  </Container>
</header>

<!-- Затемнение под меню (мобила/планшет) -->
<div
  data-menu-overlay
  class="invisible fixed inset-0 z-30 bg-charcoal/40 opacity-0 transition-opacity duration-300 ease-in-out lg:hidden"
></div>

<!-- Меню-шторка справа (мобила/планшет) -->
<aside
  data-menu
  aria-hidden="true"
  class="fixed bottom-0 right-0 top-0 z-[60] flex w-[240px] max-w-full translate-x-full flex-col bg-charcoal text-paper transition-transform duration-300 ease-in-out lg:hidden"
>
  <button
    type="button"
    data-menu-toggle
    aria-label="Закрыть меню"
    aria-expanded="false"
    class="burger menu-close absolute right-[5px] top-[5px] z-10 cursor-pointer"
  >
    <span></span><span></span><span></span><span></span>
  </button>

  <nav class="flex flex-col gap-[15px] px-[25px] pt-[42px]">
    {
      nav.map((item) => (
        <a
          href={item.href}
          data-menu-link
          class="display text-[24px] leading-none text-paper transition-colors duration-200 hover:text-grey-300"
        >
          {item.label}
        </a>
      ))
    }
  </nav>

  <div class="mt-auto flex flex-col gap-[22px] px-[25px] pb-[25px]">
    <div class="flex gap-2">
      <a href={contact.telegram} aria-label="Telegram" class="flex size-[30px] items-center justify-center rounded-full bg-paper text-charcoal transition-colors hover:bg-accent hover:text-paper">T</a>
      <a href={contact.max} aria-label="Max" class="flex size-[30px] items-center justify-center rounded-full bg-paper text-charcoal transition-colors hover:bg-accent hover:text-paper">M</a>
    </div>
    <a
      href={contact.phoneHref}
      class="inline-flex h-[50px] w-[155px] items-center justify-center rounded-[3px] bg-paper px-4 text-[14px] font-semibold tracking-[-0.5px] text-charcoal transition-colors duration-200 hover:bg-accent hover:text-paper"
    >
      {contact.phone}
    </a>
  </div>
</aside>

<style>
  .top-header {
    color: var(--color-paper);
    background: transparent;
  }
  .header-sticky {
    color: var(--color-charcoal);
    background: var(--color-paper);
    transform: translateY(-100%);
    transition: transform 350ms linear;
    pointer-events: none;
  }
  .header-sticky[data-mode="sticky"] {
    transform: translateY(0);
    pointer-events: auto;
  }
  .header-sticky[data-menu-open="true"] {
    transform: translateY(0);
    pointer-events: auto;
  }
  .top-header[data-menu-open="true"] {
    color: var(--color-paper);
  }

  .header-guides {
    color: var(--color-charcoal);
    opacity: 0;
    transition: opacity 160ms linear;
  }
  .header-sticky .header-guides {
    opacity: 1;
  }
  .header-guide {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 1px;
    background: currentColor;
    opacity: 0.04;
  }
  .header-guide-a {
    left: var(--guide-a);
  }
  .header-guide-b {
    left: var(--guide-b);
  }
  .header-guide-c {
    left: var(--guide-c);
  }
  .header-guide-bottom {
    position: absolute;
    left: var(--guide-edge-left);
    right: var(--guide-edge-right);
    bottom: 0;
    height: 1px;
    background: currentColor;
    opacity: 0.06;
  }

  /* Hover как в оригинале: текст уезжает вверх, снизу приходит серая копия. */
  .link-slide {
    overflow: hidden;
  }
  .slide-text {
    position: relative;
    display: inline-block;
    transition: transform 0.3s ease;
  }
  .slide-text::before {
    content: attr(data-text);
    position: absolute;
    top: 100%;
    left: 0;
    color: var(--color-grey-300);
    white-space: nowrap;
  }
  .link-slide:hover .slide-text,
  .link-slide:focus-visible .slide-text {
    transform: translateY(-100%);
  }

  /* Бургер: в оригинале на мобиле две тонкие линии шириной ~45px. */
  .burger {
    height: 40px;
    width: 45px;
  }
  .burger span {
    position: absolute;
    left: 0;
    right: 0;
    height: 1px;
    background: currentColor;
    transition: transform 0.3s ease-in-out, opacity 0.3s ease-in-out;
  }
  .burger span:nth-child(1) {
    top: 13px;
  }
  .burger span:nth-child(2),
  .burger span:nth-child(3) {
    display: none;
  }
  .burger span:nth-child(4) {
    bottom: 13px;
  }
  .burger[aria-expanded="true"] span:nth-child(1) {
    top: 50%;
    transform: translateY(-50%) rotate(45deg);
  }
  .burger[aria-expanded="true"] span:nth-child(4) {
    bottom: 50%;
    transform: translateY(50%) rotate(-45deg);
  }
  .menu-close {
    width: 40px;
  }
  .menu-close span {
    left: 8px;
    right: 8px;
  }

  /* Бургер должен оставаться видимым поверх открытого меню. Его цвет инвертируем
     в открытом состоянии — фон шторки тёмный, иконка светлая. */
  .burger[aria-expanded="true"] {
    color: var(--color-paper);
  }
</style>

<script>
  const topHeader = document.querySelector<HTMLElement>("[data-header-top]");
  let stickyHeader: HTMLElement | null = null;

  // В Tilda это две разные шапки: верхняя статично лежит в hero,
  // а белая fixed-шапка отдельно появляется только при обратном скролле.
  if (topHeader) {
    stickyHeader = topHeader.cloneNode(true) as HTMLElement;
    stickyHeader.removeAttribute("data-header-top");
    stickyHeader.setAttribute("data-header-sticky", "");
    stickyHeader.dataset.mode = "hidden";
    stickyHeader.className = "header-sticky fixed inset-x-0 top-0 z-50 h-[69px] lg:h-16 xl:h-[76px]";
    topHeader.after(stickyHeader);
  }

  const toggles = document.querySelectorAll<HTMLButtonElement>("[data-menu-toggle]");
  const menu = document.querySelector<HTMLElement>("[data-menu]");
  const overlay = document.querySelector<HTMLElement>("[data-menu-overlay]");
  const links = document.querySelectorAll<HTMLAnchorElement>("[data-menu-link]");

  let lastY = Math.max(window.scrollY, 0);
  let ticking = false;

  const syncHeader = () => {
    if (!stickyHeader) return;
    const y = Math.max(window.scrollY, 0);
    const delta = y - lastY;
    const scrollingUp = delta < -1;
    const scrollingDown = delta > 1;

    if (y < 800) {
      stickyHeader.dataset.mode = "hidden";
    } else if (scrollingUp) {
      stickyHeader.dataset.mode = "sticky";
    } else if (scrollingDown) {
      stickyHeader.dataset.mode = "hidden";
    }

    lastY = y;
    ticking = false;
  };

  window.addEventListener(
    "scroll",
    () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(syncHeader);
      }
    },
    { passive: true },
  );
  syncHeader();

  const setOpen = (open: boolean) => {
    if (!menu || !overlay) return;
    toggles.forEach((toggle) => toggle.setAttribute("aria-expanded", String(open)));
    menu.setAttribute("aria-hidden", String(!open));
    menu.classList.toggle("translate-x-full", !open);
    menu.classList.toggle("translate-x-0", open);
    overlay.classList.toggle("invisible", !open);
    overlay.classList.toggle("opacity-0", !open);
    topHeader?.setAttribute("data-menu-open", String(open));
    stickyHeader?.setAttribute("data-menu-open", String(open));
    document.body.style.overflow = open ? "hidden" : "";
  };

  toggles.forEach((toggle) => {
    toggle.addEventListener("click", () => {
      const isOpen = toggle.getAttribute("aria-expanded") === "true";
      setOpen(!isOpen);
    });
  });
  overlay?.addEventListener("click", () => setOpen(false));
  links.forEach((l) => l.addEventListener("click", () => setOpen(false)));
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") setOpen(false);
  });
</script>
