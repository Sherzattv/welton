---
import Container from "../Container.astro";
import GridLines from "../GridLines.astro";
import { contact } from "../../data/home";
---

<footer id="contacts" class="relative bg-charcoal text-paper">
  <GridLines />
  <Container class="relative z-10 py-16 sm:py-20">
    <div class="flex items-start justify-between">
      <a href="/" aria-label="Велес Групп" class="shrink-0">
        <img src="/img/Vector.svg" alt="Велес Групп" width="78" height="35" class="h-9 w-auto" />
      </a>
      <a
        href="#top"
        aria-label="Наверх"
        class="flex h-12 w-12 items-center justify-center border border-paper/20 transition-colors hover:border-accent hover:text-accent"
      >
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M9 17V1M1 9l8-8 8 8" stroke="currentColor" stroke-width="1.4" stroke-linecap="square"></path>
        </svg>
      </a>
    </div>

    <div class="mt-12 grid grid-cols-1 gap-10 sm:grid-cols-2">
      <div class="space-y-10">
        <div>
          <p class="text-sm text-grey-500">Адрес</p>
          <p class="mt-2 max-w-xs text-paper/90">{contact.address}</p>
        </div>
        <div>
          <p class="text-sm text-grey-500">Соцсети</p>
          <ul class="mt-2 space-y-1">
            <li>
              <a href={contact.telegram} target="_blank" rel="noopener" class="transition-colors hover:text-accent">Telegram</a>
            </li>
            <li>
              <a href={contact.max} target="_blank" rel="noopener" class="transition-colors hover:text-accent">Max</a>
            </li>
          </ul>
        </div>
      </div>

      <div>
        <p class="text-sm text-grey-500">Правовая информация</p>
        <ul class="mt-2 space-y-1">
          <li><a href="/policy" class="transition-colors hover:text-accent">Политика конфиденциальности</a></li>
          <li><a href="/agreement" class="transition-colors hover:text-accent">Пользовательское соглашение</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-16 flex flex-col justify-between gap-6 border-t border-paper/10 pt-8 sm:flex-row">
      <div class="text-sm text-grey-400">
        <p class="text-paper/90">{contact.company}</p>
        <p>ИНН: {contact.inn}</p>
        <p>КПП: {contact.kpp}</p>
      </div>
      <p class="text-sm text-grey-500">Разработка сайта</p>
    </div>

    <div class="mt-12 space-y-2">
      <a href={contact.phoneHref} class="display block text-[2.5rem] leading-none transition-colors hover:text-accent sm:text-6xl lg:text-7xl">
        {contact.phone}
      </a>
      <a href={contact.emailHref} class="display block text-[2rem] leading-none break-all transition-colors hover:text-accent sm:text-5xl lg:text-6xl">
        {contact.email}
      </a>
    </div>
  </Container>
</footer>
