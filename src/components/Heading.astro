---
// Дисплейный заголовок (Adderley, плотный негативный трекинг, капс).
interface Props {
  as?: "h1" | "h2" | "h3" | "h4";
  size?: "hero" | "xl" | "lg" | "md" | "sm";
  class?: string;
}
const { as = "h2", size = "lg", class: className = "" } = Astro.props;
const Tag = as;

const sizeClass = {
  hero: "text-hero",
  xl: "text-h1",
  lg: "text-h2",
  md: "text-h3",
  sm: "text-h4",
}[size];
---

<Tag class={`display ${sizeClass} ${className}`}>
  <slot />
</Tag>
