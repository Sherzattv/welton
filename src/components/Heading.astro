---
// Дисплейный заголовок (Adderley, плотный Tilda-трекинг, регистр из контента).
interface Props {
  as?: "h1" | "h2" | "h3" | "h4";
  size?: "hero" | "xl" | "lg" | "md" | "sm";
  class?: string;
  [key: `data-${string}`]: string | boolean | undefined;
}
const { as = "h2", size = "lg", class: className = "", ...rest } = Astro.props;
const Tag = as;

const sizes: Record<string, string> = {
  hero: "text-hero",
  xl: "text-h1",
  lg: "text-h2",
  md: "text-h3",
  sm: "text-h4",
};
const sizeClass = sizes[size];
---

<Tag class={`display ${sizeClass} ${className}`} {...rest}>
  <slot />
</Tag>
