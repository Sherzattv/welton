---
import Container from "../Container.astro";
import GridLines from "../GridLines.astro";
import Button from "../Button.astro";
---

<section id="top" class="hero-section relative overflow-hidden text-paper">
  <img
    src="/img/omni-753e3760-83e9-4.jpg"
    alt=""
    fetchpriority="high"
    class="absolute inset-0 h-full w-full object-cover"
  />
  <div class="absolute inset-0 bg-gradient-to-b from-transparent to-charcoal/50"></div>
  <GridLines />

  <Container class="hero-content absolute inset-0 z-10">
    <div class="hero-layout">
      <h1 data-split class="hero-title display">
        Остекление крупных объектов по России
      </h1>

      <div class="hero-side">
        <p data-reveal class="hero-desc">
          Проектируем, производим и монтируем оконные, фасадные и
          противопожарные конструкции для жилых, общественных и
          инфраструктурных объектов.
        </p>
        <Button variant="light" href="#invoice" class="hero-cta" data-reveal>Обсудить проект</Button>
      </div>
    </div>
  </Container>
</section>

<style>
  .hero-section {
    min-height: calc(100vw * 670 / 360);
  }

  .hero-layout {
    position: absolute;
    inset-inline: var(--spacing-gutter);
    bottom: calc(100vw * 32 / 360);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .hero-title {
    width: 100%;
    font-size: calc(100vw * 42 / 360);
    line-height: calc(100vw * 42 / 360);
    letter-spacing: -0.6px;
  }

  .hero-side {
    display: flex;
    flex-direction: column;
    gap: calc(100vw * 32 / 360);
  }

  .hero-desc {
    max-width: none;
    color: rgb(238 238 238 / 0.95);
    font-size: calc(100vw * 14 / 360);
    font-weight: 400;
    line-height: calc(100vw * 18 / 360);
    letter-spacing: -0.9px;
  }

  .hero-cta {
    width: 100%;
    height: calc(100vw * 48 / 360);
  }

  @media (min-width: 640px) {
    .hero-section {
      min-height: 640px;
    }

    .hero-layout {
      inset-inline: 24px;
      bottom: 32px;
    }

    .hero-title {
      font-size: 64px;
      line-height: 0.9;
      letter-spacing: -0.5px;
    }

    .hero-side {
      gap: 32px;
    }

    .hero-desc {
      max-width: 380px;
      font-size: 14px;
      line-height: 18px;
      letter-spacing: -0.6px;
    }

    .hero-cta {
      width: 218px;
      height: 48px;
    }
  }

  @media (min-width: 1200px) {
    .hero-section {
      min-height: clamp(640px, 53.333vw, 768px);
    }

    .hero-layout {
      inset-inline: var(--spacing-gutter);
      bottom: clamp(18px, 1.5vw, 21.6px);
      flex-direction: row;
      align-items: stretch;
      justify-content: space-between;
      gap: 0;
    }

    .hero-title {
      width: 41.75vw;
      font-size: clamp(72px, 6vw, 86.4px);
      line-height: 0.9;
      letter-spacing: -0.01em;
    }

    .hero-side {
      width: 23.2vw;
      max-width: none;
      justify-content: space-between;
      gap: 0;
    }

    .hero-desc {
      max-width: none;
      font-size: clamp(14px, 1.15vw, 16.56px);
      line-height: 1.3;
      letter-spacing: -0.6px;
    }

    .hero-cta {
      width: 100%;
      height: clamp(48px, 4vw, 57.6px);
      margin-bottom: clamp(14px, 1.17vw, 16.8px);
    }
  }
</style>
