---
import Container from "../Container.astro";
import GridLines from "../GridLines.astro";
import Button from "../Button.astro";
---

<section
  id="top"
  class="relative flex min-h-[640px] items-end overflow-hidden pb-10 text-paper sm:pb-12"
>
  <img
    src="/img/omni-753e3760-83e9-4.jpg"
    alt=""
    fetchpriority="high"
    class="absolute inset-0 h-full w-full object-cover"
  />
  <div class="absolute inset-0 bg-gradient-to-b from-transparent to-charcoal/50"></div>
  <GridLines />

  <Container class="relative z-10">
    <div class="flex flex-col gap-10 lg:flex-row lg:justify-between lg:gap-12">
      <h1
        data-split
        class="display max-w-[14ch] text-[clamp(2.5rem,6vw,6rem)] leading-[0.9] tracking-[-0.01em] lg:max-w-[41vw]"
      >
        Остекление крупных объектов по России
      </h1>

      <div class="flex flex-col gap-8 lg:max-w-[24vw] lg:justify-between lg:gap-0">
        <p data-reveal class="max-w-[340px] text-[clamp(0.82rem,1.15vw,1.05rem)] leading-[1.3] tracking-[-0.02em] text-paper lg:max-w-none">
          Проектируем, производим и монтируем оконные, фасадные и
          противопожарные конструкции для жилых, общественных и
          инфраструктурных объектов.
        </p>
        <Button variant="light" href="#invoice" class="self-start" data-reveal>Обсудить проект</Button>
      </div>
    </div>
  </Container>
</section>
