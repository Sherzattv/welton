---
import Container from "@components/Container.astro";
import GridLines from "@components/GridLines.astro";
import Button from "@components/Button.astro";
import { asset } from "@lib/asset";
---

<section id="top" class="hero-section relative overflow-hidden text-paper">
  <img
    src={asset("/img/omni-753e3760-83e9-4.jpg")}
    alt=""
    fetchpriority="high"
    class="absolute inset-0 h-full w-full object-cover"
  />
  <div
    class="absolute inset-0 bg-gradient-to-b from-transparent to-charcoal/50"
  >
  </div>
  <GridLines />

  <Container class="hero-content absolute inset-0 z-10">
    <div class="hero-layout">
      <h1 data-split class="hero-title display">
        <span class="hero-title-line">Строим</span>
        <span class="hero-title-line">частные дома</span>
        <span class="hero-title-line">по Казахстану</span>
      </h1>

      <div class="hero-side">
        <p data-reveal class="hero-desc">
          Проектируем и строим частные дома по разным технологиям — камень,
          монолит, СИП-панели. От проекта до готового дома, по всему Казахстану.
        </p>
        <Button variant="light" href="#invoice" class="hero-cta" data-reveal
          >Обсудить проект</Button
        >
      </div>
    </div>
  </Container>
</section>

<style>
  .hero-section {
    min-height: calc(100vw * 670 / 360);
  }

  .hero-layout {
    position: absolute;
    inset-inline: var(--spacing-gutter);
    bottom: calc(100vw * 32 / 360);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .hero-title {
    width: 100%;
    font-size: calc(100vw * 42 / 360);
    line-height: calc(100vw * 42 / 360);
    letter-spacing: -0.6px;
  }

  .hero-title-line {
    display: inline;
  }

  .hero-title-line:not(:last-child)::after {
    content: " ";
  }

  @media (min-width: 960px) {
    .hero-title-line {
      display: block;
    }

    .hero-title-line:not(:last-child)::after {
      content: "";
    }
  }

  .hero-side {
    display: flex;
    flex-direction: column;
    gap: calc(100vw * 32 / 360);
  }

  .hero-desc {
    max-width: none;
    color: rgb(238 238 238 / 0.95);
    font-size: calc(100vw * 14 / 360);
    font-weight: 400;
    line-height: calc(100vw * 18 / 360);
    letter-spacing: -0.9px;
  }

  .hero-cta {
    width: 100%;
    height: calc(100vw * 48 / 360);
  }

  @media (min-width: 640px) {
    .hero-section {
      min-height: 640px;
    }

    .hero-layout {
      inset-inline: 24px;
      bottom: 32px;
    }

    .hero-title {
      font-size: 64px;
      line-height: 0.9;
      letter-spacing: -0.5px;
    }

    .hero-side {
      gap: 32px;
    }

    .hero-desc {
      max-width: 380px;
      font-size: 14px;
      line-height: 18px;
      letter-spacing: -0.6px;
    }

    .hero-cta {
      width: 218px;
      height: 48px;
    }
  }

  @media (min-width: 960px) and (max-width: 1199px) {
    .hero-layout {
      inset-inline: 24px;
      bottom: 40px;
      flex-direction: row;
      align-items: stretch;
      justify-content: space-between;
      gap: 0;
    }

    .hero-title {
      width: 420px;
      font-size: 64px;
      line-height: 0.9;
      letter-spacing: -0.5px;
    }

    .hero-side {
      width: 219px;
      justify-content: space-between;
      gap: 0;
    }

    .hero-desc {
      max-width: none;
      font-size: 14px;
      line-height: 18px;
      letter-spacing: -0.6px;
    }

    .hero-cta {
      width: 219px;
      height: 48px;
    }
  }

  @media (min-width: 1200px) {
    .hero-section {
      min-height: clamp(640px, 53.333vw, 768px);
    }

    .hero-layout {
      inset-inline: var(--spacing-gutter);
      bottom: clamp(18px, 1.5vw, 21.6px);
      flex-direction: row;
      align-items: stretch;
      justify-content: space-between;
      gap: 0;
    }

    .hero-title {
      width: 41.75vw;
      min-height: clamp(195px, 16.25vw, 234px);
      font-size: clamp(72px, 6vw, 86.4px);
      line-height: 0.9;
      letter-spacing: -0.5px;
    }

    .hero-side {
      width: 23.2vw;
      max-width: none;
      justify-content: space-between;
      gap: 0;
    }

    .hero-desc {
      max-width: none;
      font-size: 16px;
      line-height: normal;
      letter-spacing: normal;
    }

    .hero-cta {
      width: 100%;
      height: clamp(48px, 4vw, 58px);
      margin-bottom: clamp(14px, 1.17vw, 16.8px);
    }
  }
</style>
