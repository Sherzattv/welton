---
import Layout from "@layouts/Layout.astro";
import Section from "@components/Section.astro";
import Heading from "@components/Heading.astro";
import Button from "@components/Button.astro";
import ProjectCard from "@components/ProjectCard.astro";

const colors = [
  {
    name: "charcoal",
    hex: "#1b1b1b",
    cls: "bg-charcoal",
    note: "фон + чернила",
  },
  { name: "ink", hex: "#0e100f", cls: "bg-ink", note: "глубокий фон" },
  {
    name: "paper",
    hex: "#eeeeee",
    cls: "bg-paper",
    note: "бумага / текст на тёмном",
  },
  { name: "white", hex: "#ffffff", cls: "bg-white", note: "чистый белый" },
  { name: "grey-200", hex: "#dddddd", cls: "bg-grey-200", note: "линии" },
  {
    name: "grey-300",
    hex: "#c3c3c3",
    cls: "bg-grey-300",
    note: "слабый текст",
  },
  {
    name: "grey-400",
    hex: "#9a9a9a",
    cls: "bg-grey-400",
    note: "приглушённый текст",
  },
  {
    name: "grey-500",
    hex: "#767676",
    cls: "bg-grey-500",
    note: "вторичный текст",
  },
  {
    name: "accent",
    hex: "#22866b",
    cls: "bg-accent",
    note: "ЕДИНСТВЕННЫЙ акцент",
  },
  {
    name: "accent-hover",
    hex: "#1e785f",
    cls: "bg-accent-hover",
    note: "ховер акцента",
  },
];

const typeScale = [
  { label: "Heading hero", size: "hero" as const },
  { label: "Heading xl", size: "xl" as const },
  { label: "Heading lg", size: "lg" as const },
  { label: "Heading md", size: "md" as const },
  { label: "Heading sm", size: "sm" as const },
];

const bodyScale = [
  { label: "Body 20 / Light", cls: "text-xl" },
  { label: "Body 18 / Light", cls: "text-lg" },
  { label: "Body 16 / Regular", cls: "text-base font-normal" },
  { label: "Body 14 / Regular", cls: "text-sm font-normal" },
  { label: "Caption 12 / Medium", cls: "text-xs font-medium text-grey-400" },
];
---

<Layout title="Дизайн-система — Велес Групп">
  <Section tone="charcoal">
    <p class="text-sm tracking-widest text-accent uppercase">Дизайн-система</p>
    <Heading as="h1" size="xl" class="mt-3">Велес Групп</Heading>
    <p class="mt-4 max-w-xl text-grey-400">
      Монохром-уголь, один зелёный акцент, острые углы, тяжёлый дисплейный шрифт
      над лёгким текстом. Источник истины для всех страниц.
    </p>
  </Section>

  <!-- Палитра -->
  <Section tone="paper">
    <Heading as="h2" size="md" class="text-charcoal">Палитра</Heading>
    <div class="mt-8 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-5">
      {
        colors.map((c) => (
          <div class="border border-grey-200">
            <div class={`${c.cls} h-24 w-full border-b border-black/5`} />
            <div class="px-3 py-3 text-charcoal">
              <p class="font-medium">{c.name}</p>
              <p class="text-sm text-grey-500">{c.hex}</p>
              <p class="mt-1 text-xs text-grey-400">{c.note}</p>
            </div>
          </div>
        ))
      }
    </div>
  </Section>

  <!-- Типографика -->
  <Section tone="charcoal">
    <Heading as="h2" size="md">Типографика</Heading>

    <div class="mt-10 space-y-6">
      <p class="text-sm tracking-widest text-grey-500 uppercase">
        Дисплей — Adderley Bold
      </p>
      {
        typeScale.map((t) => (
          <div class="flex flex-col gap-1 border-b border-white/10 pb-6">
            <span class="text-xs text-grey-500">{t.label}</span>
            <Heading as="h3" size={t.size}>
              Остекление объектов
            </Heading>
          </div>
        ))
      }
    </div>

    <div class="mt-12 space-y-4">
      <p class="text-sm tracking-widest text-grey-500 uppercase">
        Текст — Inter
      </p>
      {
        bodyScale.map((t) => (
          <div class="flex flex-col gap-1">
            <span class="text-xs text-grey-500">{t.label}</span>
            <p class={t.cls}>
              Проектируем, производим и монтируем оконные, фасадные и
              противопожарные конструкции.
            </p>
          </div>
        ))
      }
    </div>
  </Section>

  <!-- Кнопки -->
  <Section tone="paper">
    <Heading as="h2" size="md" class="text-charcoal">Кнопки</Heading>
    <div class="mt-8 flex flex-wrap items-center gap-5">
      <Button variant="light" href="#">Обсудить проект</Button>
      <Button variant="accent" href="#">Оставить заявку</Button>
    </div>
    <p class="mt-8 mb-3 text-sm text-grey-500">На тёмном фоне:</p>
    <div class="flex flex-wrap items-center gap-5 bg-charcoal p-8">
      <Button variant="light" href="#">Обсудить проект</Button>
      <Button variant="outline" href="#">Все проекты</Button>
    </div>
  </Section>

  <!-- Карточки каталога -->
  <Section tone="charcoal">
    <Heading as="h2" size="md">Карточка проекта</Heading>
    <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <ProjectCard number="01" title="Жилой комплекс" location="Москва" />
      <ProjectCard
        number="02"
        title="Бизнес-центр"
        location="Санкт-Петербург"
      />
      <ProjectCard number="03" title="Терминал аэропорта" location="Казань" />
    </div>
  </Section>
</Layout>
