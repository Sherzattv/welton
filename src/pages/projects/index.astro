---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import Layout from "@layouts/Layout.astro";
import Motion from "@components/Motion.astro";
import Header from "@layout/Header.astro";
import Footer from "@layout/Footer.astro";
import Container from "@components/Container.astro";
import GridLines from "@components/GridLines.astro";
import Heading from "@components/Heading.astro";
import ProjectCard from "@components/ProjectCard.astro";
import CatalogFilters from "@components/projects/CatalogFilters.astro";
import { asset } from "@lib/asset";
import { projectCode, projectFile, projectTitle } from "@lib/projectAsset";
import heroBg from "../../assets/dom-hero.jpg";

const projects = (await getCollection("projects")).sort((a, b) =>
  a.data.folder.localeCompare(b.data.folder),
);
---

<Layout
  title="Проекты welton — каталог готовых решений"
  description="Каталог проектов welton: 82 готовых проекта частных домов разных площадей и этажности. Адаптируем под ваш участок."
>
  <Motion />
  <Header />
  <main>
    <section
      class="catalog-hero relative overflow-hidden bg-charcoal text-paper"
    >
      <Image
        src={heroBg}
        alt=""
        widths={[768, 1280, 1920]}
        sizes="100vw"
        format="webp"
        quality={72}
        loading="eager"
        fetchpriority="high"
        decoding="async"
        class="catalog-hero-bg absolute inset-0 h-full w-full object-cover"
      />
      <div
        class="absolute inset-0 bg-gradient-to-b from-charcoal/55 via-charcoal/45 to-charcoal/85"
      >
      </div>
      <GridLines />
      <Container class="relative z-10">
        <div class="catalog-hero-inner">
          <Heading as="h1" size="hero" class="catalog-hero-title" data-split>
            Проекты домов
          </Heading>
          <p class="catalog-hero-lead text-grey-200" data-reveal>
            Готовые проекты разных площадей и технологий. Адаптируем под ваш
            участок, бюджет и сценарий жизни — без переделки с нуля.
          </p>
        </div>
      </Container>
    </section>

    <section
      class="catalog-shell relative bg-paper text-charcoal"
      style="overflow-x: clip"
    >
      <GridLines />
      <CatalogFilters total={projects.length} />

      <div class="catalog-main">
        <ul class="catalog-grid">
          {
            projects.map((p) => {
              const cover = p.data.renders[0] ?? p.data.facade;
              return (
                <li
                  data-catalog-item
                  data-floors={p.data.floors}
                  data-area={p.data.area}
                  data-bedrooms={p.data.bedrooms ?? 0}
                  data-code={projectCode(p.data)}
                >
                  <ProjectCard
                    title={projectTitle(p.data)}
                    code={projectCode(p.data)}
                    tagline={p.data.tagline}
                    image={projectFile(p.data.folder, cover, true)}
                    href={asset(`/projects/${p.id}/`)}
                    area={p.data.area}
                    width={p.data.width}
                    depth={p.data.depth}
                    floors={p.data.floors}
                  />
                </li>
              );
            })
          }
        </ul>

        <div class="catalog-empty" data-catalog-empty>
          <p class="catalog-empty-title">Ничего не нашли</p>
          <p class="catalog-empty-hint">
            Попробуйте увеличить диапазон площади или снять часть фильтров.
          </p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .catalog-hero-inner {
    padding-top: clamp(120px, 14vw, 220px);
    padding-bottom: clamp(56px, 6vw, 120px);
    max-width: 920px;
  }

  .catalog-hero-title {
    text-transform: uppercase;
  }

  .catalog-hero-lead {
    margin-top: clamp(20px, 2vw, 32px);
    max-width: 56ch;
    font-size: clamp(0.95rem, 1.1vw, 1.125rem);
    line-height: 1.5;
  }

  /* ─── Shell: на десктопе фильтры слева (1/4), сетка справа (3/4) ─── */
  .catalog-shell {
    display: grid;
    grid-template-columns: 1fr;
  }

  @media (min-width: 960px) {
    .catalog-shell {
      grid-template-columns: minmax(280px, 25%) 1fr;
      /* align-items оставляем default (stretch), чтобы aside растянулся
         на всю высоту сетки и sticky внутри работал по всему скроллу */
    }
  }

  .catalog-main {
    padding: clamp(32px, 4vw, 64px) var(--spacing-gutter);
  }

  .catalog-grid {
    display: grid;
    gap: clamp(16px, 1.5vw, 28px);
    grid-template-columns: 1fr;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .catalog-grid > .is-hidden {
    display: none;
  }

  @media (min-width: 640px) {
    .catalog-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1200px) {
    .catalog-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Empty state — показываем JS-логикой через .is-visible */
  .catalog-empty {
    display: none;
    padding-block: clamp(80px, 8vw, 140px);
    text-align: center;
  }

  .catalog-empty.is-visible {
    display: block;
  }

  .catalog-empty-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw, 3rem);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--color-charcoal);
    text-transform: uppercase;
  }

  .catalog-empty-hint {
    margin-top: 16px;
    color: var(--color-grey-500);
    max-width: 40ch;
    margin-inline: auto;
    line-height: 1.5;
  }
</style>
