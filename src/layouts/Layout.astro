---
import "@fontsource-variable/inter";
import "@styles/global.css";
import CustomCursor from "@components/CustomCursor.astro";
import { asset } from "@lib/asset";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "welton — строительство частных домов в Казахстане",
  description = "Строим частные дома под ключ по разным технологиям — камень, монолит, СИП — по всему Казахстану.",
} = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={asset("/favicon.svg")} />
    <title>{title}</title>
    <!-- Включаем моушн-режим до первой отрисовки: так reveal-блоки скрыты
         заранее (без мигания), а при reduced-motion класс не ставится и
         весь контент остаётся видимым даже без JS. -->
    <script is:inline>
      if (!matchMedia("(prefers-reduced-motion: reduce)").matches) {
        document.documentElement.classList.add("motion");
      }
    </script>
  </head>
  <body class="min-h-screen bg-charcoal text-paper antialiased">
    <slot />
    <CustomCursor />
  </body>
</html>
