---
import "@fontsource-variable/inter";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Велес Групп — остекление крупных объектов по России",
  description = "Проектируем, производим и монтируем оконные, фасадные и противопожарные конструкции для жилых, общественных и инфраструктурных объектов.",
} = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-charcoal text-paper antialiased">
    <slot />
  </body>
</html>
