---
// Шаблон детальной страницы проекта.
// Все 82 проекта рендерятся по этому шаблону — повторяемые блоки в фиксированном порядке.
// Контент сквозных блоков (FullCycle, Customization, Partners, CtaCalc, Advantages)
// одинаков на всех страницах: единый источник правды.
import Layout from "@layouts/Layout.astro";
import Motion from "@components/Motion.astro";
import Header from "@layout/Header.astro";
import Footer from "@layout/Footer.astro";
import Partners from "@sections/Partners.astro";
import CtaCalc from "@sections/CtaCalc.astro";
import Advantages from "@sections/Advantages.astro";
import Hero from "@components/project/Hero.astro";
import Specs from "@components/project/Specs.astro";
import Renders from "@components/project/Renders.astro";
import Floorplans from "@components/project/Floorplans.astro";
import Facade from "@components/project/Facade.astro";
import FullCycle from "@components/project/FullCycle.astro";
import Customization from "@components/project/Customization.astro";
import { projectTitle } from "@lib/projectAsset";

interface Props {
  data: {
    folder: string;
    area: number;
    width: number;
    depth: number;
    floors: number;
    facade: string;
    renders: string[];
    floorplans: string[];
    title?: string;
    description?: string;
    bedrooms?: number;
    bathrooms?: number;
    wallMaterial?: string;
    wallThickness?: string;
    roof?: string;
  };
}
const { data } = Astro.props;
const title = projectTitle(data);
---

<Layout
  title={`${title} — проект дома от welton`}
  description={data.description ??
    `Проект частного дома площадью ${data.area} м², ${data.width}×${data.depth} м, ${data.floors} ${data.floors === 1 ? "этаж" : "этажа"}. Адаптируем под ваш участок.`}
>
  <Motion />
  <Header />
  <main>
    <Hero
      folder={data.folder}
      title={title}
      description={data.description}
      facade={data.facade}
      area={data.area}
      floors={data.floors}
    />
    <Specs
      area={data.area}
      width={data.width}
      depth={data.depth}
      floors={data.floors}
      bedrooms={data.bedrooms}
      bathrooms={data.bathrooms}
      wallMaterial={data.wallMaterial}
      wallThickness={data.wallThickness}
      roof={data.roof}
    />
    <Renders folder={data.folder} renders={data.renders} />
    <Floorplans folder={data.folder} floorplans={data.floorplans} />
    <Facade folder={data.folder} facade={data.facade} />
    <FullCycle />
    <Customization />
    <Partners />
    <CtaCalc />
    <Advantages />
  </main>
  <Footer />
</Layout>
